{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"MAL","translationId":"fra_lsg","name":"MALACHIE","commonName":"MALACHIE","title":"MALACHIE","order":39,"numberOfChapters":4,"sha256":"7967d8f8d59dd7aa359cb14fcd1efbb83c6070d8a4e54536ad3b0d27daf9a636","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/MAL/1.json","lastChapterNumber":4,"lastChapterApiLink":"/api/fra_lsg/MAL/4.json","totalNumberOfVerses":55},"chapter":{"number":4,"content":[{"type":"verse","number":1,"content":[{"text":"Car voici, le jour vient,","poem":1},{"lineBreak":true},{"text":"Ardent comme une fournaise.","poem":1},{"lineBreak":true},{"text":"Tous les hautains et tous les méchants seront comme du chaume;","poem":1},{"lineBreak":true},{"text":"Le jour qui vient les embrasera,","poem":1},{"lineBreak":true},{"text":"Dit l’Éternel des armées,","poem":1},{"lineBreak":true},{"text":"Il ne leur laissera ni racine ni rameau.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Mais pour vous qui craignez mon nom, se lèvera","poem":1},{"lineBreak":true},{"text":"Le soleil de la justice,","poem":1},{"lineBreak":true},{"text":"Et la guérison sera sous ses ailes;","poem":1},{"lineBreak":true},{"text":"Vous sortirez, et vous sauterez comme les veaux d’une étable,","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Et vous foulerez les méchants,","poem":1},{"lineBreak":true},{"text":"Car ils seront comme de la cendre","poem":1},{"lineBreak":true},{"text":"Sous la plante de vos pieds,","poem":1},{"lineBreak":true},{"text":"Au jour que je prépare,","poem":1},{"lineBreak":true},{"text":"Dit l’Éternel des armées.","poem":1}]},{"type":"verse","number":4,"content":[{"text":"Souvenez-vous de la loi de Moïse, mon serviteur,","poem":1},{"lineBreak":true},{"text":"Auquel j’ai prescrit en Horeb, pour tout Israël,","poem":1},{"lineBreak":true},{"text":"Des préceptes et des ordonnances.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Voici, je vous enverrai Élie, le prophète,","poem":1},{"lineBreak":true},{"text":"Avant que le jour de l’Éternel arrive,","poem":1},{"lineBreak":true},{"text":"Ce jour grand et redoutable.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il ramènera le cœur des pères à leurs enfants,","poem":1},{"lineBreak":true},{"text":"Et le cœur des enfants à leurs pères,","poem":1},{"lineBreak":true},{"text":"De peur que je ne vienne frapper le pays d’interdit.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/MAL/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/MAT/1.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/MAL/3.json","previousChapterAudioLinks":{},"numberOfVerses":6}