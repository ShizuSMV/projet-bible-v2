{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":4,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Avec instruments à cordes. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Quand je crie, réponds-moi, Dieu de ma justice!","poem":1},{"lineBreak":true},{"text":"Quand je suis dans la détresse, sauve-moi!","poem":1},{"lineBreak":true},{"text":"Aie pitié de moi, écoute ma prière!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Fils des hommes, jusques à quand ma gloire sera-t-elle outragée?","poem":1},{"lineBreak":true},{"text":"Jusques à quand aimerez-vous la vanité,","poem":1},{"lineBreak":true},{"text":"Chercherez-vous le mensonge? — Pause.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Sachez que l’Éternel s’est choisi un homme pieux;","poem":1},{"lineBreak":true},{"text":"L’Éternel entend, quand je crie à lui.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Tremblez, et ne péchez point;","poem":1},{"lineBreak":true},{"text":"Parlez en vos cœurs sur votre couche, puis taisez-vous. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Offrez des sacrifices de justice,","poem":1},{"lineBreak":true},{"text":"Et confiez-vous à l’Éternel.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Plusieurs disent: Qui nous fera voir le bonheur?","poem":1},{"lineBreak":true},{"text":"Fais lever sur nous la lumière de ta face, ô Éternel!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Tu mets dans mon cœur plus de joie qu’ils n’en ont","poem":1},{"lineBreak":true},{"text":"Quand abondent leur froment et leur moût.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Je me couche et je m’endors en paix,","poem":1},{"lineBreak":true},{"text":"Car toi seul, ô Éternel! tu me donnes la sécurité dans ma demeure.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/3.json","previousChapterAudioLinks":{},"numberOfVerses":9}