{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":132,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés.","poem":1},{"lineBreak":true},{"text":"Éternel, souviens-toi de David,","poem":1},{"lineBreak":true},{"text":"De toutes ses peines!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Il jura à l’Éternel,","poem":1},{"lineBreak":true},{"text":"Il fit ce vœu au puissant de Jacob:","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Je n’entrerai pas dans la tente où j’habite,","poem":1},{"lineBreak":true},{"text":"Je ne monterai pas sur le lit où je repose,","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Je ne donnerai ni sommeil à mes yeux,","poem":1},{"lineBreak":true},{"text":"Ni assoupissement à mes paupières,","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Jusqu’à ce que j’aie trouvé un lieu pour l’Éternel,","poem":1},{"lineBreak":true},{"text":"Une demeure pour le puissant de Jacob.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Voici, nous en entendîmes parler à Éphrata,","poem":1},{"lineBreak":true},{"text":"Nous la trouvâmes dans les champs de Jaar…","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Allons à sa demeure,","poem":1},{"lineBreak":true},{"text":"Prosternons-nous devant son marchepied!…","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Lève-toi, Éternel, viens à ton lieu de repos,","poem":1},{"lineBreak":true},{"text":"Toi et l’arche de ta majesté!","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Que tes sacrificateurs soient revêtus de justice,","poem":1},{"lineBreak":true},{"text":"Et que tes fidèles poussent des cris de joie!","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"A cause de David, ton serviteur,","poem":1},{"lineBreak":true},{"text":"Ne repousse pas ton oint!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"L’Éternel a juré la vérité à David,","poem":1},{"lineBreak":true},{"text":"Il n’en reviendra pas;","poem":1},{"lineBreak":true},{"text":"Je mettrai sur ton trône un fruit de tes entrailles.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Si tes fils observent mon alliance","poem":1},{"lineBreak":true},{"text":"Et mes préceptes que je leur enseigne,","poem":1},{"lineBreak":true},{"text":"Leurs fils aussi pour toujours","poem":1},{"lineBreak":true},{"text":"Seront assis sur ton trône.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Oui, l’Éternel a choisi Sion,","poem":1},{"lineBreak":true},{"text":"Il l’a désirée pour sa demeure:","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"C’est mon lieu de repos à toujours;","poem":1},{"lineBreak":true},{"text":"J’y habiterai, car je l’ai désirée.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Je bénirai sa nourriture,","poem":1},{"lineBreak":true},{"text":"Je rassasierai de pain ses indigents;","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Je revêtirai de salut ses sacrificateurs,","poem":1},{"lineBreak":true},{"text":"Et ses fidèles pousseront des cris de joie.","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Là j’élèverai la puissance de David,","poem":1},{"lineBreak":true},{"text":"Je préparerai une lampe à mon oint,","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"Je revêtirai de honte ses ennemis,","poem":1},{"lineBreak":true},{"text":"Et sur lui brillera sa couronne.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/132.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/133.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/131.json","previousChapterAudioLinks":{},"numberOfVerses":18}