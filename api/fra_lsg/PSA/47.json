{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":47,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Des fils de Koré. Psaume.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Vous tous, peuples, battez des mains!","poem":1},{"lineBreak":true},{"text":"Poussez vers Dieu des cris de joie!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Car l’Éternel, le Très-Haut, est redoutable,","poem":1},{"lineBreak":true},{"text":"Il est un grand roi sur toute la terre.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Il nous assujettit des peuples,","poem":1},{"lineBreak":true},{"text":"Il met des nations sous nos pieds;","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Il nous choisit notre héritage,","poem":1},{"lineBreak":true},{"text":"La gloire de Jacob qu’il aime. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Dieu monte au milieu des cris de triomphe,","poem":1},{"lineBreak":true},{"text":"L’Éternel s’avance au son de la trompette.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Chantez à Dieu, chantez!","poem":1},{"lineBreak":true},{"text":"Chantez à notre roi, chantez!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Car Dieu est roi de toute la terre:","poem":1},{"lineBreak":true},{"text":"Chantez un cantique!","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Dieu règne sur les nations,","poem":1},{"lineBreak":true},{"text":"Dieu a pour siège son saint trône.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Les princes des peuples se réunissent","poem":1},{"lineBreak":true},{"text":"Au peuple du Dieu d’Abraham;","poem":1},{"lineBreak":true},{"text":"Car à Dieu sont les boucliers de la terre:","poem":1},{"lineBreak":true},{"text":"Il est souverainement élevé.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/47.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/48.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/46.json","previousChapterAudioLinks":{},"numberOfVerses":10}