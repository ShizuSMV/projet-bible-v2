{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":20,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Que l’Éternel t’exauce au jour de la détresse,","poem":1},{"lineBreak":true},{"text":"Que le nom du Dieu de Jacob te protège!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Que du sanctuaire il t’envoie du secours,","poem":1},{"lineBreak":true},{"text":"Que de Sion il te soutienne!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Qu’il se souvienne de toutes tes offrandes,","poem":1},{"lineBreak":true},{"text":"Et qu’il agrée tes holocaustes! — Pause.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Qu’il te donne ce que ton cœur désire,","poem":1},{"lineBreak":true},{"text":"Et qu’il accomplisse tous tes desseins!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Nous nous réjouirons de ton salut,","poem":1},{"lineBreak":true},{"text":"Nous lèverons l’étendard au nom de notre Dieu;","poem":1},{"lineBreak":true},{"text":"L’Éternel exaucera tous tes vœux.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je sais déjà que l’Éternel sauve son oint;","poem":1},{"lineBreak":true},{"text":"Il l’exaucera des cieux, de sa sainte demeure,","poem":1},{"lineBreak":true},{"text":"Par le secours puissant de sa droite.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Ceux-ci s’appuient sur leurs chars, ceux-là sur leurs chevaux;","poem":1},{"lineBreak":true},{"text":"Nous, nous invoquons le nom de l’Éternel, notre Dieu.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Eux, ils plient, et ils tombent;","poem":1},{"lineBreak":true},{"text":"Nous, nous tenons ferme, et restons debout.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Éternel, sauve le roi!","poem":1},{"lineBreak":true},{"text":"Qu’il nous exauce, quand nous l’invoquons!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/20.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/21.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/19.json","previousChapterAudioLinks":{},"numberOfVerses":10}