{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":92,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume. Cantique pour le jour du sabbat.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Il est beau de louer l’Éternel,","poem":1},{"lineBreak":true},{"text":"Et de célébrer ton nom, ô Très-Haut!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"D’annoncer le matin ta bonté,","poem":1},{"lineBreak":true},{"text":"Et ta fidélité pendant les nuits,","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Sur l’instrument à dix cordes et sur le luth,","poem":1},{"lineBreak":true},{"text":"Aux sons de la harpe.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Tu me réjouis par tes œuvres, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Et je chante avec allégresse l’ouvrage de tes mains.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Que tes œuvres sont grandes, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Que tes pensées sont profondes!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"L’homme stupide n’y connaît rien,","poem":1},{"lineBreak":true},{"text":"Et l’insensé n’y prend point garde.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Si les méchants croissent comme l’herbe,","poem":1},{"lineBreak":true},{"text":"Si tous ceux qui font le mal fleurissent,","poem":1},{"lineBreak":true},{"text":"C’est pour être anéantis à jamais.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Mais toi, tu es le Très-Haut,","poem":1},{"lineBreak":true},{"text":"A perpétuité, ô Éternel!","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Car voici, tes ennemis, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Car voici, tes ennemis périssent;","poem":1},{"lineBreak":true},{"text":"Tous ceux qui font le mal sont dispersés.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Et tu me donnes la force du buffle;","poem":1},{"lineBreak":true},{"text":"Je suis arrosé avec une huile fraîche.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Mon œil se plaît à contempler mes ennemis,","poem":1},{"lineBreak":true},{"text":"Et mon oreille à entendre mes méchants adversaires.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Les justes croissent comme le palmier,","poem":1},{"lineBreak":true},{"text":"Ils s’élèvent comme le cèdre du Liban.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Plantés dans la maison de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Ils prospèrent dans les parvis de notre Dieu;","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Ils portent encore des fruits dans la vieillesse,","poem":1},{"lineBreak":true},{"text":"Ils sont pleins de sève et verdoyants,","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Pour faire connaître que l’Éternel est juste.","poem":1},{"lineBreak":true},{"text":"Il est mon rocher, et il n’y a point en lui d’iniquité.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/92.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/93.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/91.json","previousChapterAudioLinks":{},"numberOfVerses":16}