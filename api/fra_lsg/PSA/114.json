{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":114,"content":[{"type":"verse","number":1,"content":[{"text":"Quand Israël sortit d’Égypte,","poem":1},{"lineBreak":true},{"text":"Quand la maison de Jacob s’éloigna d’un peuple barbare,","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Juda devint son sanctuaire,","poem":1},{"lineBreak":true},{"text":"Israël fut son domaine.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"La mer le vit et s’enfuit,","poem":1},{"lineBreak":true},{"text":"Le Jourdain retourna en arrière;","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Les montagnes sautèrent comme des béliers,","poem":1},{"lineBreak":true},{"text":"Les collines comme des agneaux.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Qu’as-tu, mer, pour t’enfuir,","poem":1},{"lineBreak":true},{"text":"Jourdain, pour retourner en arrière?","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Qu’avez-vous, montagnes, pour sauter comme des béliers,","poem":1},{"lineBreak":true},{"text":"Et vous, collines, comme des agneaux?","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Tremble devant le Seigneur, ô terre!","poem":1},{"lineBreak":true},{"text":"Devant le Dieu de Jacob,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Qui change le rocher en étang,","poem":1},{"lineBreak":true},{"text":"Le roc en source d’eaux.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/114.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/115.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/113.json","previousChapterAudioLinks":{},"numberOfVerses":8}