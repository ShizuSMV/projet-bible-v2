{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":21,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Éternel! Le roi se réjouit de ta protection puissante.","poem":1},{"lineBreak":true},{"text":"Oh! Comme ton secours le remplit d’allégresse!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Tu lui as donné ce que désirait son cœur,","poem":1},{"lineBreak":true},{"text":"Et tu n’as pas refusé ce que demandaient ses lèvres. — Pause.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Car tu l’as prévenu par les bénédictions de ta grâce,","poem":1},{"lineBreak":true},{"text":"Tu as mis sur sa tête une couronne d’or pur.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Il te demandait la vie, tu la lui as donnée,","poem":1},{"lineBreak":true},{"text":"Une vie longue pour toujours et à perpétuité.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Sa gloire est grande à cause de ton secours;","poem":1},{"lineBreak":true},{"text":"Tu places sur lui l’éclat et la magnificence.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Tu le rends à jamais un objet de bénédictions,","poem":1},{"lineBreak":true},{"text":"Tu le combles de joie devant ta face.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Le roi se confie en l’Éternel;","poem":1},{"lineBreak":true},{"text":"Et, par la bonté du Très-Haut, il ne chancelle pas.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Ta main trouvera tous tes ennemis,","poem":1},{"lineBreak":true},{"text":"Ta droite trouvera ceux qui te haïssent.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Tu les rendras tels qu’une fournaise ardente,","poem":1},{"lineBreak":true},{"text":"Le jour où tu te montreras;","poem":1},{"lineBreak":true},{"text":"L’Éternel les anéantira dans sa colère,","poem":1},{"lineBreak":true},{"text":"Et le feu les dévorera.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Tu feras disparaître leur postérité de la terre,","poem":1},{"lineBreak":true},{"text":"Et leur race du milieu des fils de l’homme.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Ils ont projeté du mal contre toi,","poem":1},{"lineBreak":true},{"text":"Ils ont conçu de mauvais desseins, mais ils seront impuissants.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Car tu leur feras tourner le dos,","poem":1},{"lineBreak":true},{"text":"Et avec ton arc tu tireras sur eux.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Lève-toi, Éternel, avec ta force!","poem":1},{"lineBreak":true},{"text":"Nous voulons chanter, célébrer ta puissance.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/21.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/22.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/20.json","previousChapterAudioLinks":{},"numberOfVerses":14}