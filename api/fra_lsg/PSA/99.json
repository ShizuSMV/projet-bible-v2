{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":99,"content":[{"type":"verse","number":1,"content":[{"text":"L’Éternel règne: les peuples tremblent;","poem":1},{"lineBreak":true},{"text":"Il est assis sur les chérubins: la terre chancelle.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"L’Éternel est grand dans Sion,","poem":1},{"lineBreak":true},{"text":"Il est élevé au-dessus de tous les peuples.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Qu’on célèbre ton nom grand et redoutable!","poem":1},{"lineBreak":true},{"text":"Il est saint!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Qu’on célèbre la force du roi qui aime la justice!","poem":1},{"lineBreak":true},{"text":"Tu affermis la droiture,","poem":1},{"lineBreak":true},{"text":"Tu exerces en Jacob la justice et l’équité.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Exaltez l’Éternel, notre Dieu,","poem":1},{"lineBreak":true},{"text":"Et prosternez-vous devant son marchepied!","poem":1},{"lineBreak":true},{"text":"Il est saint!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Moïse et Aaron parmi ses sacrificateurs,","poem":1},{"lineBreak":true},{"text":"Et Samuel parmi ceux qui invoquaient son nom,","poem":1},{"lineBreak":true},{"text":"Invoquèrent l’Éternel, et il les exauça.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Il leur parla dans la colonne de nuée;","poem":1},{"lineBreak":true},{"text":"Ils observèrent ses commandements","poem":1},{"lineBreak":true},{"text":"Et la loi qu’il leur donna.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Éternel, notre Dieu, tu les exauças,","poem":1},{"lineBreak":true},{"text":"Tu fus pour eux un Dieu qui pardonne,","poem":1},{"lineBreak":true},{"text":"Mais tu les as punis de leurs fautes.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Exaltez l’Éternel, notre Dieu,","poem":1},{"lineBreak":true},{"text":"Et prosternez-vous sur sa montagne sainte!","poem":1},{"lineBreak":true},{"text":"Car il est saint, l’Éternel, notre Dieu!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/99.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/100.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/98.json","previousChapterAudioLinks":{},"numberOfVerses":9}