{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":146,"content":[{"type":"verse","number":1,"content":[{"text":"Louez l’Éternel!","poem":1},{"lineBreak":true},{"text":"Mon âme, loue l’Éternel!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Je louerai l’Éternel tant que je vivrai,","poem":1},{"lineBreak":true},{"text":"Je célébrerai mon Dieu tant que j’existerai.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Ne vous confiez pas aux grands,","poem":1},{"lineBreak":true},{"text":"Aux fils de l’homme, qui ne peuvent sauver.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Leur souffle s’en va, ils rentrent dans la terre,","poem":1},{"lineBreak":true},{"text":"Et ce même jour leurs desseins périssent.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Heureux celui qui a pour secours le Dieu de Jacob,","poem":1},{"lineBreak":true},{"text":"Qui met son espoir en l’Éternel, son Dieu!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il a fait les cieux et la terre,","poem":1},{"lineBreak":true},{"text":"La mer et tout ce qui s’y trouve.","poem":1},{"lineBreak":true},{"text":"Il garde la fidélité à toujours.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Il fait droit aux opprimés;","poem":1},{"lineBreak":true},{"text":"Il donne du pain aux affamés;","poem":1},{"lineBreak":true},{"text":"L’Éternel délivre les captifs;","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"L’Éternel ouvre les yeux des aveugles;","poem":1},{"lineBreak":true},{"text":"L’Éternel redresse ceux qui sont courbés;","poem":1},{"lineBreak":true},{"text":"L’Éternel aime les justes.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"L’Éternel protège les étrangers,","poem":1},{"lineBreak":true},{"text":"Il soutient l’orphelin et la veuve,","poem":1},{"lineBreak":true},{"text":"Mais il renverse la voie des méchants.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"L’Éternel règne éternellement;","poem":1},{"lineBreak":true},{"text":"Ton Dieu, ô Sion! Subsiste d’âge en âge!","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/146.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/147.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/145.json","previousChapterAudioLinks":{},"numberOfVerses":10}