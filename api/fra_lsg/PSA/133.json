{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":133,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés. De David.","poem":1},{"lineBreak":true},{"text":"Voici, oh! Qu’il est agréable, qu’il est doux","poem":1},{"lineBreak":true},{"text":"Pour des frères de demeurer ensemble!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"C’est comme l’huile précieuse qui, répandue sur la tête,","poem":1},{"lineBreak":true},{"text":"Descend sur la barbe, sur la barbe d’Aaron,","poem":1},{"lineBreak":true},{"text":"Qui descend sur le bord de ses vêtements.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"C’est comme la rosée de l’Hermon,","poem":1},{"lineBreak":true},{"text":"Qui descend sur les montagnes de Sion;","poem":1},{"lineBreak":true},{"text":"Car c’est là que l’Éternel envoie la bénédiction,","poem":1},{"lineBreak":true},{"text":"La vie, pour l’éternité.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/133.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/134.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/132.json","previousChapterAudioLinks":{},"numberOfVerses":3}