{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":148,"content":[{"type":"verse","number":1,"content":[{"text":"Louez l’Éternel!","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel du haut des cieux!","poem":1},{"lineBreak":true},{"text":"Louez-le dans les lieux élevés!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Louez-le, vous tous ses anges!","poem":1},{"lineBreak":true},{"text":"Louez-le, vous toutes ses armées!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Louez-le, soleil et lune!","poem":1},{"lineBreak":true},{"text":"Louez-le, vous toutes, étoiles lumineuses!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Louez-le, cieux des cieux,","poem":1},{"lineBreak":true},{"text":"Et vous, eaux qui êtes au-dessus des cieux!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Qu’ils louent le nom de l’Éternel!","poem":1},{"lineBreak":true},{"text":"Car il a commandé, et ils ont été créés.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il les a affermis pour toujours et à perpétuité;","poem":1},{"lineBreak":true},{"text":"Il a donné des lois, et il ne les violera point.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Louez l’Éternel du bas de la terre,","poem":1},{"lineBreak":true},{"text":"Monstres marins, et vous tous, abîmes,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Feu et grêle, neige et brouillards,","poem":1},{"lineBreak":true},{"text":"Vents impétueux, qui exécutez ses ordres,","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Montagnes et toutes les collines,","poem":1},{"lineBreak":true},{"text":"Arbres fruitiers et tous les cèdres,","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Animaux et tout le bétail,","poem":1},{"lineBreak":true},{"text":"Reptiles et oiseaux ailés,","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Rois de la terre et tous les peuples,","poem":1},{"lineBreak":true},{"text":"Princes et tous les juges de la terre,","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Jeunes hommes et jeunes filles,","poem":1},{"lineBreak":true},{"text":"Vieillards et enfants!","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Qu’ils louent le nom de l’Éternel!","poem":1},{"lineBreak":true},{"text":"Car son nom seul est élevé;","poem":1},{"lineBreak":true},{"text":"Sa majesté est au-dessus de la terre et des cieux.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Il a relevé la force de son peuple:","poem":1},{"lineBreak":true},{"text":"Sujet de louange pour tous ses fidèles,","poem":1},{"lineBreak":true},{"text":"Pour les enfants d’Israël, du peuple qui est près de lui.","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/148.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/149.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/147.json","previousChapterAudioLinks":{},"numberOfVerses":14}