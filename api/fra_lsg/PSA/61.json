{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":61,"content":[{"type":"verse","number":1,"content":["Au chef des chantres. Sur instruments à cordes. De David."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"O Dieu! Écoute mes cris,","poem":1},{"lineBreak":true},{"text":"Sois attentif à ma prière!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Du bout de la terre je crie à toi, le cœur abattu;","poem":1},{"lineBreak":true},{"text":"Conduis-moi sur le rocher que je ne puis atteindre!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Car tu es pour moi un refuge,","poem":1},{"lineBreak":true},{"text":"Une tour forte, en face de l’ennemi.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Je voudrais séjourner éternellement dans ta tente,","poem":1},{"lineBreak":true},{"text":"Me réfugier à l’abri de tes ailes. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Car toi, ô Dieu! Tu exauces mes vœux,","poem":1},{"lineBreak":true},{"text":"Tu me donnes l’héritage de ceux qui craignent ton nom.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Ajoute des jours aux jours du roi;","poem":1},{"lineBreak":true},{"text":"Que ses années se prolongent à jamais!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Qu’il reste sur le trône éternellement devant Dieu!","poem":1},{"lineBreak":true},{"text":"Fais que ta bonté et ta fidélité veillent sur lui!","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Alors je chanterai sans cesse ton nom,","poem":1},{"lineBreak":true},{"text":"En accomplissant chaque jour mes vœux.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/61.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/62.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/60.json","previousChapterAudioLinks":{},"numberOfVerses":9}