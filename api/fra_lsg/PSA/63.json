{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":63,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume de David. Lorsqu’il était dans le désert de Juda.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"O Dieu! Tu es mon Dieu, je te cherche;","poem":1},{"lineBreak":true},{"text":"Mon âme a soif de toi, mon corps soupire après toi,","poem":1},{"lineBreak":true},{"text":"Dans une terre aride, desséchée, sans eau.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Ainsi je te contemple dans le sanctuaire,","poem":1},{"lineBreak":true},{"text":"Pour voir ta puissance et ta gloire.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Car ta bonté vaut mieux que la vie:","poem":1},{"lineBreak":true},{"text":"Mes lèvres célèbrent tes louanges.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Je te bénirai donc toute ma vie,","poem":1},{"lineBreak":true},{"text":"J’élèverai mes mains en ton nom.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Mon âme sera rassasiée comme de mets gras et succulents,","poem":1},{"lineBreak":true},{"text":"Et, avec des cris de joie sur les lèvres, ma bouche te célébrera.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Lorsque je pense à toi sur ma couche,","poem":1},{"lineBreak":true},{"text":"Je médite sur toi pendant les veilles de la nuit.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Car tu es mon secours,","poem":1},{"lineBreak":true},{"text":"Et je suis dans l’allégresse à l’ombre de tes ailes.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Mon âme est attachée à toi;","poem":1},{"lineBreak":true},{"text":"Ta droite me soutient.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Mais ceux qui cherchent à m’ôter la vie","poem":1},{"lineBreak":true},{"text":"Iront dans les profondeurs de la terre;","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Ils seront livrés au glaive,","poem":1},{"lineBreak":true},{"text":"Ils seront la proie des chacals.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Et le roi se réjouira en Dieu;","poem":1},{"lineBreak":true},{"text":"Quiconque jure par lui s’en glorifiera,","poem":1},{"lineBreak":true},{"text":"Car la bouche des menteurs sera fermée.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/63.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/64.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/62.json","previousChapterAudioLinks":{},"numberOfVerses":12}