{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":[{"text":"Heureux l’homme qui ne marche pas selon le conseil des méchants,","poem":1},{"lineBreak":true},{"text":"Qui ne s’arrête pas sur la voie des pécheurs,","poem":1},{"lineBreak":true},{"text":"Et qui ne s’assied pas en compagnie des moqueurs,","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Mais qui trouve son plaisir dans la loi de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Et qui la médite jour et nuit!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Il est comme un arbre planté près d’un courant d’eau,","poem":1},{"lineBreak":true},{"text":"Qui donne son fruit en sa saison,","poem":1},{"lineBreak":true},{"text":"Et dont le feuillage ne se flétrit point:","poem":1},{"lineBreak":true},{"text":"Tout ce qu’il fait lui réussit.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Il n’en est pas ainsi des méchants:","poem":1},{"lineBreak":true},{"text":"Ils sont comme la paille que le vent dissipe.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"C’est pourquoi les méchants ne résistent pas au jour du jugement,","poem":1},{"lineBreak":true},{"text":"Ni les pécheurs dans l’assemblée des justes;","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Car l’Éternel connaît la voie des justes,","poem":1},{"lineBreak":true},{"text":"Et la voie des pécheurs mène à la ruine.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/JOB/42.json","previousChapterAudioLinks":{},"numberOfVerses":6}