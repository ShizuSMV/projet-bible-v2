{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":15,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume de David.","poem":1},{"lineBreak":true},{"text":"O Éternel! Qui séjournera dans ta tente?","poem":1},{"lineBreak":true},{"text":"Qui demeurera sur ta montagne sainte?","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Celui qui marche dans l’intégrité, qui pratique la justice","poem":1},{"lineBreak":true},{"text":"Et qui dit la vérité selon son cœur.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Il ne calomnie point avec sa langue,","poem":1},{"lineBreak":true},{"text":"Il ne fait point de mal à son semblable,","poem":1},{"lineBreak":true},{"text":"Et il ne jette point l’opprobre sur son prochain.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Il regarde avec dédain celui qui est méprisable,","poem":1},{"lineBreak":true},{"text":"Mais il honore ceux qui craignent l’Éternel;","poem":1},{"lineBreak":true},{"text":"Il ne se rétracte point, s’il fait un serment à son préjudice.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Il n’exige point d’intérêt de son argent,","poem":1},{"lineBreak":true},{"text":"Et il n’accepte point de don contre l’innocent.","poem":1},{"lineBreak":true},{"text":"Celui qui se conduit ainsi ne chancelle jamais.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/15.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/16.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/14.json","previousChapterAudioLinks":{},"numberOfVerses":5}