{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":115,"content":[{"type":"verse","number":1,"content":[{"text":"Non pas à nous, Éternel, non pas à nous,","poem":1},{"lineBreak":true},{"text":"Mais à ton nom donne gloire,","poem":1},{"lineBreak":true},{"text":"A cause de ta bonté, à cause de ta fidélité!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Pourquoi les nations diraient-elles:","poem":1},{"lineBreak":true},{"text":"Où donc est leur Dieu?","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Notre Dieu est au ciel,","poem":1},{"lineBreak":true},{"text":"Il fait tout ce qu’il veut.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Leurs idoles sont de l’argent et de l’or,","poem":1},{"lineBreak":true},{"text":"Elles sont l’ouvrage de la main des hommes.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Elles ont une bouche et ne parlent point,","poem":1},{"lineBreak":true},{"text":"Elles ont des yeux et ne voient point,","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Elles ont des oreilles et n’entendent point,","poem":1},{"lineBreak":true},{"text":"Elles ont un nez et ne sentent point,","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Elles ont des mains et ne touchent point,","poem":1},{"lineBreak":true},{"text":"Des pieds et ne marchent point,","poem":1},{"lineBreak":true},{"text":"Elles ne produisent aucun son dans leur gosier.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Ils leur ressemblent, ceux qui les fabriquent,","poem":1},{"lineBreak":true},{"text":"Tous ceux qui se confient en elles.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Israël, confie-toi en l’Éternel!","poem":1},{"lineBreak":true},{"text":"Il est leur secours et leur bouclier.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Maison d’Aaron, confie-toi en l’Éternel!","poem":1},{"lineBreak":true},{"text":"Il est leur secours et leur bouclier.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Vous qui craignez l’Éternel, confiez-vous en l’Éternel!","poem":1},{"lineBreak":true},{"text":"Il est leur secours et leur bouclier.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"L’Éternel se souvient de nous: il bénira,","poem":1},{"lineBreak":true},{"text":"Il bénira la maison d’Israël,","poem":1},{"lineBreak":true},{"text":"Il bénira la maison d’Aaron,","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Il bénira ceux qui craignent l’Éternel,","poem":1},{"lineBreak":true},{"text":"Les petits et les grands;","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"L’Éternel vous multipliera ses faveurs,","poem":1},{"lineBreak":true},{"text":"A vous et à vos enfants.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Soyez bénis par l’Éternel,","poem":1},{"lineBreak":true},{"text":"Qui a fait les cieux et la terre!","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Les cieux sont les cieux de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Mais il a donné la terre aux fils de l’homme.","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Ce ne sont pas les morts qui célèbrent l’Éternel,","poem":1},{"lineBreak":true},{"text":"Ce n’est aucun de ceux qui descendent dans le lieu du silence;","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"Mais nous, nous bénirons l’Éternel,","poem":1},{"lineBreak":true},{"text":"Dès maintenant et à jamais.","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/115.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/116.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/114.json","previousChapterAudioLinks":{},"numberOfVerses":18}