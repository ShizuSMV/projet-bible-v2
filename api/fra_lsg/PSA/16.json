{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":16,"content":[{"type":"verse","number":1,"content":[{"text":"Hymne de David.","poem":1},{"lineBreak":true},{"text":"Garde-moi, ô Dieu! Car je cherche en toi mon refuge.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Je dis à l’Éternel: Tu es mon Seigneur,","poem":1},{"lineBreak":true},{"text":"Tu es mon souverain bien!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Les saints qui sont dans le pays,","poem":1},{"lineBreak":true},{"text":"Les hommes pieux sont l’objet de toute mon affection.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"On multiplie les idoles, on court après les dieux étrangers:","poem":1},{"lineBreak":true},{"text":"Je ne répands pas leurs libations de sang,","poem":1},{"lineBreak":true},{"text":"Je ne mets pas leurs noms sur mes lèvres.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"L’Éternel est mon partage et mon calice;","poem":1},{"lineBreak":true},{"text":"C’est toi qui m’assures mon lot;","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Un héritage délicieux m’est échu,","poem":1},{"lineBreak":true},{"text":"Une belle possession m’est accordée.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je bénis l’Éternel, mon conseiller;","poem":1},{"lineBreak":true},{"text":"La nuit même mon cœur m’exhorte.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"J’ai constamment l’Éternel sous mes yeux;","poem":1},{"lineBreak":true},{"text":"Quand il est à ma droite, je ne chancelle pas.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Aussi mon cœur est dans la joie, mon esprit dans l’allégresse,","poem":1},{"lineBreak":true},{"text":"Et mon corps repose en sécurité.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Car tu ne livreras pas mon âme au séjour des morts,","poem":1},{"lineBreak":true},{"text":"Tu ne permettras pas que ton bien-aimé voie la corruption.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Tu me feras connaître le sentier de la vie;","poem":1},{"lineBreak":true},{"text":"Il y a d’abondantes joies devant ta face,","poem":1},{"lineBreak":true},{"text":"Des délices éternelles à ta droite.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/16.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/17.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/15.json","previousChapterAudioLinks":{},"numberOfVerses":11}