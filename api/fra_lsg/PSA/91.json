{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":91,"content":[{"type":"verse","number":1,"content":[{"text":"Celui qui demeure sous l’abri du Très-Haut","poem":1},{"lineBreak":true},{"text":"Repose à l’ombre du Tout-Puissant.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Je dis à l’Éternel: Mon refuge et ma forteresse,","poem":1},{"lineBreak":true},{"text":"Mon Dieu en qui je me confie!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Car c’est lui qui te délivre du filet de l’oiseleur,","poem":1},{"lineBreak":true},{"text":"De la peste et de ses ravages.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Il te couvrira de ses plumes,","poem":1},{"lineBreak":true},{"text":"Et tu trouveras un refuge sous ses ailes;","poem":1},{"lineBreak":true},{"text":"Sa fidélité est un bouclier et une cuirasse.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Tu ne craindras ni les terreurs de la nuit,","poem":1},{"lineBreak":true},{"text":"Ni la flèche qui vole de jour,","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Ni la peste qui marche dans les ténèbres,","poem":1},{"lineBreak":true},{"text":"Ni la contagion qui frappe en plein midi.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Que mille tombent à ton côté,","poem":1},{"lineBreak":true},{"text":"Et dix mille à ta droite,","poem":1},{"lineBreak":true},{"text":"Tu ne seras pas atteint;","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"De tes yeux seulement tu regarderas,","poem":1},{"lineBreak":true},{"text":"Et tu verras la rétribution des méchants.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Car tu es mon refuge, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Tu fais du Très-Haut ta retraite.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Aucun malheur ne t’arrivera,","poem":1},{"lineBreak":true},{"text":"Aucun fléau n’approchera de ta tente.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Car il ordonnera à ses anges","poem":1},{"lineBreak":true},{"text":"De te garder dans toutes tes voies;","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Ils te porteront sur les mains,","poem":1},{"lineBreak":true},{"text":"De peur que ton pied ne heurte contre une pierre.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Tu marcheras sur le lion et sur l’aspic,","poem":1},{"lineBreak":true},{"text":"Tu fouleras le lionceau et le dragon.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Puisqu’il m’aime, je le délivrerai;","poem":1},{"lineBreak":true},{"text":"Je le protégerai, puisqu’il connaît mon nom.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Il m’invoquera, et je lui répondrai;","poem":1},{"lineBreak":true},{"text":"Je serai avec lui dans la détresse,","poem":1},{"lineBreak":true},{"text":"Je le délivrerai et je le glorifierai.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Je le rassasierai de longs jours,","poem":1},{"lineBreak":true},{"text":"Et je lui ferai voir mon salut.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/91.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/92.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/90.json","previousChapterAudioLinks":{},"numberOfVerses":16}