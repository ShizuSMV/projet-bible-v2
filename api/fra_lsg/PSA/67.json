nations sur la terre. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Les peuples te louent, ô Dieu!","poem":1},{"lineBreak":true},{"text":"Tous les peuples te louent.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"La terre donne ses produits;","poem":1},{"lineBreak":true},{"text":"Dieu, notre Dieu, nous bénit.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Dieu, nous bénit,","poem":1},{"lineBreak":true},{"text":"Et toutes les extrémités de la terre le craignent.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/67.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/68.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/66.json","previousChapterAudioLinks":{},"numberOfVerses":8}