{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":142,"content":[{"type":"verse","number":1,"content":["Cantique de David. Lorsqu’il était dans la caverne. Prière."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"De ma voix je crie à l’Éternel,","poem":1},{"lineBreak":true},{"text":"De ma voix j’implore l’Éternel.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Je répands ma plainte devant lui,","poem":1},{"lineBreak":true},{"text":"Je lui raconte ma détresse.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Quand mon esprit est abattu au-dedans de moi,","poem":1},{"lineBreak":true},{"text":"Toi, tu connais mon sentier.","poem":1},{"lineBreak":true},{"text":"Sur la route où je marche","poem":1},{"lineBreak":true},{"text":"Ils m’ont tendu un piège.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Jette les yeux à droite, et regarde!","poem":1},{"lineBreak":true},{"text":"Personne ne me reconnaît,","poem":1},{"lineBreak":true},{"text":"Tout refuge est perdu pour moi,","poem":1},{"lineBreak":true},{"text":"Nul ne prend souci de mon âme.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Éternel! C’est à toi que je crie.","poem":1},{"lineBreak":true},{"text":"Je dis: Tu es mon refuge,","poem":1},{"lineBreak":true},{"text":"Mon partage sur la terre des vivants.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Sois attentif à mes cris!","poem":1},{"lineBreak":true},{"text":"Car je suis bien malheureux.","poem":1},{"lineBreak":true},{"text":"Délivre-moi de ceux qui me poursuivent!","poem":1},{"lineBreak":true},{"text":"Car ils sont plus forts que moi.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Tire mon âme de sa prison,","poem":1},{"lineBreak":true},{"text":"Afin que je célèbre ton nom!","poem":1},{"lineBreak":true},{"text":"Les justes viendront m’entourer,","poem":1},{"lineBreak":true},{"text":"Quand tu m’auras fait du bien.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/142.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/143.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/141.json","previousChapterAudioLinks":{},"numberOfVerses":8}