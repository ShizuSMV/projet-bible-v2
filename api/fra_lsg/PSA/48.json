{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":48,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique. Psaume des fils de Koré.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"L’Éternel est grand, il est l’objet de toutes les louanges,","poem":1},{"lineBreak":true},{"text":"Dans la ville de notre Dieu, sur sa montagne sainte.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Belle est la colline, joie de toute la terre, la montagne de Sion;","poem":1},{"lineBreak":true},{"text":"Le côté septentrional, c’est la ville du grand roi.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Dieu, dans ses palais, est connu pour une haute retraite.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Car voici, les rois s’étaient concertés:","poem":1},{"lineBreak":true},{"text":"Ils n’ont fait que passer ensemble.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Ils ont regardé, tout stupéfaits,","poem":1},{"lineBreak":true},{"text":"Ils ont eu peur, et ont pris la fuite.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Là un tremblement les a saisis,","poem":1},{"lineBreak":true},{"text":"Comme la douleur d’une femme qui accouche.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Ils ont été chassés comme par le vent d’orient,","poem":1},{"lineBreak":true},{"text":"Qui brise les navires de Tarsis.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Ce que nous avions entendu dire, nous l’avons vu","poem":1},{"lineBreak":true},{"text":"Dans la ville de l’Éternel des armées,","poem":1},{"lineBreak":true},{"text":"Dans la ville de notre Dieu:","poem":1},{"lineBreak":true},{"text":"Dieu la fera subsister à toujours. — Pause.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"O Dieu, nous pensons à ta bonté","poem":1},{"lineBreak":true},{"text":"Au milieu de ton temple.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Comme ton nom, ô Dieu!","poem":1},{"lineBreak":true},{"text":"Ta louange retentit jusqu’aux extrémités de la terre;","poem":1},{"lineBreak":true},{"text":"Ta droite est pleine de justice.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"La montagne de Sion se réjouit,","poem":1},{"lineBreak":true},{"text":"Les filles de Juda sont dans l’allégresse,","poem":1},{"lineBreak":true},{"text":"A cause de tes jugements.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Parcourez Sion, parcourez-en l’enceinte,","poem":1},{"lineBreak":true},{"text":"Comptez ses tours,","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Observez son rempart,","poem":1},{"lineBreak":true},{"text":"Examinez ses palais,","poem":1},{"lineBreak":true},{"text":"Pour le raconter à la génération future.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Voilà le Dieu qui est notre Dieu éternellement et à jamais;","poem":1},{"lineBreak":true},{"text":"Il sera notre guide jusqu’à la mort.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/48.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/49.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/47.json","previousChapterAudioLinks":{},"numberOfVerses":15}