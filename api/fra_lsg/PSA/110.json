{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":110,"content":[{"type":"verse","number":1,"content":[{"text":"De David. Psaume.","poem":1},{"lineBreak":true},{"text":"Parole de l’Éternel à mon Seigneur:","poem":1},{"lineBreak":true},{"text":"Assieds-toi à ma droite,","poem":1},{"lineBreak":true},{"text":"Jusqu’à ce que je fasse de tes ennemis ton marchepied.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"L’Éternel étendra de Sion le sceptre de ta puissance:","poem":1},{"lineBreak":true},{"text":"Domine au milieu de tes ennemis!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Ton peuple est plein d’ardeur, quand tu rassembles ton armée;","poem":1},{"lineBreak":true},{"text":"Avec des ornements sacrés, du sein de l’aurore","poem":1},{"lineBreak":true},{"text":"Ta jeunesse vient à toi comme une rosée.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"L’Éternel l’a juré, et il ne s’en repentira point:","poem":1},{"lineBreak":true},{"text":"Tu es sacrificateur pour toujours,","poem":1},{"lineBreak":true},{"text":"A la manière de Melchisédek.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Le Seigneur, à ta droite,","poem":1},{"lineBreak":true},{"text":"Brise des rois au jour de sa colère.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il exerce la justice parmi les nations: tout est plein de cadavres;","poem":1},{"lineBreak":true},{"text":"Il brise des têtes sur toute l’étendue du pays.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Il boit au torrent pendant la marche:","poem":1},{"lineBreak":true},{"text":"C’est pourquoi il relève la tête.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/110.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/111.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/109.json","previousChapterAudioLinks":{},"numberOfVerses":7}