{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":149,"content":[{"type":"verse","number":1,"content":[{"text":"Louez l’Éternel!","poem":1},{"lineBreak":true},{"text":"Chantez à l’Éternel un cantique nouveau!","poem":1},{"lineBreak":true},{"text":"Chantez ses louanges dans l’assemblée des fidèles!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Qu’Israël se réjouisse en celui qui l’a créé!","poem":1},{"lineBreak":true},{"text":"Que les fils de Sion soient dans l’allégresse à cause de leur roi!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Qu’ils louent son nom avec des danses,","poem":1},{"lineBreak":true},{"text":"Qu’ils le célèbrent avec le tambourin et la harpe!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Car l’Éternel prend plaisir à son peuple,","poem":1},{"lineBreak":true},{"text":"Il glorifie les malheureux en les sauvant.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Que les fidèles triomphent dans la gloire,","poem":1},{"lineBreak":true},{"text":"Qu’ils poussent des cris de joie sur leur couche!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Que les louanges de Dieu soient dans leur bouche,","poem":1},{"lineBreak":true},{"text":"Et le glaive à deux tranchants dans leur main,","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Pour exercer la vengeance sur les nations,","poem":1},{"lineBreak":true},{"text":"Pour châtier les peuples,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Pour lier leurs rois avec des chaînes","poem":1},{"lineBreak":true},{"text":"Et leurs grands avec des ceps de fer,","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Pour exécuter contre eux le jugement qui est écrit!","poem":1},{"lineBreak":true},{"text":"C’est une gloire pour tous ses fidèles.","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/149.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/150.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/148.json","previousChapterAudioLinks":{},"numberOfVerses":9}