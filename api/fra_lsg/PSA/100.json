{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":100,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume de louange.","poem":1},{"lineBreak":true},{"text":"Poussez vers l’Éternel des cris de joie,","poem":1},{"lineBreak":true},{"text":"Vous tous, habitants de la terre!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Servez l’Éternel, avec joie,","poem":1},{"lineBreak":true},{"text":"Venez avec allégresse en sa présence!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Sachez que l’Éternel est Dieu!","poem":1},{"lineBreak":true},{"text":"C’est lui qui nous a faits, et nous lui appartenons;","poem":1},{"lineBreak":true},{"text":"Nous sommes son peuple, et le troupeau de son pâturage.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Entrez dans ses portes avec des louanges,","poem":1},{"lineBreak":true},{"text":"Dans ses parvis avec des cantiques!","poem":1},{"lineBreak":true},{"text":"Célébrez-le, bénissez son nom!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Car l’Éternel est bon; sa bonté dure toujours,","poem":1},{"lineBreak":true},{"text":"Et sa fidélité de génération en génération.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/100.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/101.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/99.json","previousChapterAudioLinks":{},"numberOfVerses":5}