{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":83,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique. Psaume d’Asaph.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"O Dieu, ne reste pas dans le silence!","poem":1},{"lineBreak":true},{"text":"Ne te tais pas, et ne te repose pas, ô Dieu!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Car voici, tes ennemis s’agitent,","poem":1},{"lineBreak":true},{"text":"Ceux qui te haïssent lèvent la tête.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Ils forment contre ton peuple des projets pleins de ruse,","poem":1},{"lineBreak":true},{"text":"Et ils délibèrent contre ceux que tu protèges.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Venez, disent-ils, exterminons-les du milieu des nations,","poem":1},{"lineBreak":true},{"text":"Et qu’on ne se souvienne plus du nom d’Israël!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Ils se concertent tous d’un même cœur,","poem":1},{"lineBreak":true},{"text":"Ils font une alliance contre toi;","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Les tentes d’Édom et les Ismaélites,","poem":1},{"lineBreak":true},{"text":"Moab et les Hagaréniens,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Guebal, Ammon, Amalek,","poem":1},{"lineBreak":true},{"text":"Les Philistins avec les habitants de Tyr;","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"L’Assyrie aussi se joint à eux,","poem":1},{"lineBreak":true},{"text":"Elle prête son bras aux enfants de Lot. — Pause.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Traite-les comme Madian,","poem":1},{"lineBreak":true},{"text":"Comme Sisera, comme Jabin au torrent de Kison!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Ils ont été détruits à En-Dor,","poem":1},{"lineBreak":true},{"text":"Ils sont devenus du fumier pour la terre.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Traite leurs chefs comme Oreb et Zeeb,","poem":1},{"lineBreak":true},{"text":"Et tous leurs princes comme Zébach et Tsalmunna!","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Car ils disent: Emparons-nous","poem":1},{"lineBreak":true},{"text":"Des demeures de Dieu!","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Mon Dieu! Rends-les semblables au tourbillon,","poem":1},{"lineBreak":true},{"text":"Au chaume qu’emporte le vent,","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Au feu qui brûle la forêt,","poem":1},{"lineBreak":true},{"text":"A la flamme qui embrase les montagnes!","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Poursuis-les ainsi de ta tempête,","poem":1},{"lineBreak":true},{"text":"Et fais-les trembler par ton ouragan!","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Couvre leur face d’ignominie,","poem":1},{"lineBreak":true},{"text":"Afin qu’ils cherchent ton nom, ô Éternel!","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"Qu’ils soient confus et épouvantés pour toujours,","poem":1},{"lineBreak":true},{"text":"Qu’ils soient honteux et qu’ils périssent!","poem":1}]},{"type":"verse","number":19,"content":[{"lineBreak":true},{"text":"Qu’ils sachent que toi seul, dont le nom est l’Éternel,","poem":1},{"lineBreak":true},{"text":"Tu es le Très-Haut sur toute la terre!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/83.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/84.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/82.json","previousChapterAudioLinks":{},"numberOfVerses":19}