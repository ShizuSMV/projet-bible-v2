]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Ceux qui sèment avec larmes","poem":1},{"lineBreak":true},{"text":"Moissonneront avec chants d’allégresse.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Celui qui marche en pleurant, quand il porte la semence,","poem":1},{"lineBreak":true},{"text":"Revient avec allégresse, quand il porte ses gerbes.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/126.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/127.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/125.json","previousChapterAudioLinks":{},"numberOfVerses":6}