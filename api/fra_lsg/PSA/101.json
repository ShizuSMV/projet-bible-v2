{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":101,"content":[{"type":"verse","number":1,"content":[{"text":"De David. Psaume.","poem":1},{"lineBreak":true},{"text":"Je chanterai la bonté et la justice;","poem":1},{"lineBreak":true},{"text":"C’est à toi, Éternel! Que je chanterai.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Je prendrai garde à la voie droite.","poem":1},{"lineBreak":true},{"text":"Quand viendras-tu à moi?","poem":1},{"lineBreak":true},{"text":"Je marcherai dans l’intégrité de mon cœur,","poem":1},{"lineBreak":true},{"text":"Au milieu de ma maison.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Je ne mettrai rien de mauvais devant mes yeux;","poem":1},{"lineBreak":true},{"text":"Je hais la conduite des pécheurs;","poem":1},{"lineBreak":true},{"text":"Elle ne s’attachera point à moi.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Le cœur pervers s’éloignera de moi;","poem":1},{"lineBreak":true},{"text":"Je ne veux pas connaître le méchant.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Celui qui calomnie en secret son prochain, je l’anéantirai;","poem":1},{"lineBreak":true},{"text":"Celui qui a des regards hautains et un cœur enflé, je ne le supporterai pas.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"J’aurai les yeux sur les fidèles du pays,","poem":1},{"lineBreak":true},{"text":"Pour qu’ils demeurent auprès de moi;","poem":1},{"lineBreak":true},{"text":"Celui qui marche dans une voie intègre sera mon serviteur.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Celui qui se livre à la fraude n’habitera pas dans ma maison;","poem":1},{"lineBreak":true},{"text":"Celui qui dit des mensonges ne subsistera pas en ma présence.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Chaque matin j’anéantirai tous les méchants du pays,","poem":1},{"lineBreak":true},{"text":"Afin d’exterminer de la ville de l’Éternel","poem":1},{"lineBreak":true},{"text":"Tous ceux qui commettent l’iniquité.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/101.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/102.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/100.json","previousChapterAudioLinks":{},"numberOfVerses":8}