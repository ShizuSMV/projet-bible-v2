{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":29,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume de David.","poem":1},{"lineBreak":true},{"text":"Fils de Dieu, rendez à l’Éternel,","poem":1},{"lineBreak":true},{"text":"Rendez à l’Éternel gloire et honneur!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Rendez à l’Éternel gloire pour son nom!","poem":1},{"lineBreak":true},{"text":"Prosternez-vous devant l’Éternel avec des ornements sacrés!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"La voix de l’Éternel retentit sur les eaux,","poem":1},{"lineBreak":true},{"text":"Le Dieu de gloire fait gronder le tonnerre;","poem":1},{"lineBreak":true},{"text":"L’Éternel est sur les grandes eaux.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"La voix de l’Éternel est puissante,","poem":1},{"lineBreak":true},{"text":"La voix de l’Éternel est majestueuse.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"La voix de l’Éternel brise les cèdres;","poem":1},{"lineBreak":true},{"text":"L’Éternel brise les cèdres du Liban,","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il les fait bondir comme des veaux,","poem":1},{"lineBreak":true},{"text":"Et le Liban et le Sirion comme de jeunes buffles.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"La voix de l’Éternel fait jaillir des flammes de feu.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"La voix de l’Éternel fait trembler le désert;","poem":1},{"lineBreak":true},{"text":"L’Éternel fait trembler le désert de Kadès.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"La voix de l’Éternel fait enfanter les biches,","poem":1},{"lineBreak":true},{"text":"Elle dépouille les forêts.","poem":1},{"lineBreak":true},{"text":"Dans son palais tout s’écrie: Gloire!","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"L’Éternel était sur son trône lors du déluge;","poem":1},{"lineBreak":true},{"text":"L’Éternel sur son trône règne éternellement.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"L’Éternel donne la force à son peuple;","poem":1},{"lineBreak":true},{"text":"L’Éternel bénit son peuple et le rend heureux.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/29.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/30.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/28.json","previousChapterAudioLinks":{},"numberOfVerses":11}