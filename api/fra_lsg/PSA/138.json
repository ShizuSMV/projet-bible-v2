{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":138,"content":[{"type":"verse","number":1,"content":[{"text":"De David.","poem":1},{"lineBreak":true},{"text":"Je te célèbre de tout mon cœur,","poem":1},{"lineBreak":true},{"text":"Je chante tes louanges en la présence de Dieu.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Je me prosterne dans ton saint temple,","poem":1},{"lineBreak":true},{"text":"Et je célèbre ton nom, à cause de ta bonté et de ta fidélité,","poem":1},{"lineBreak":true},{"text":"Car ta renommée s’est accrue par l’accomplissement de tes promesses.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Le jour où je t’ai invoqué, tu m’as exaucé,","poem":1},{"lineBreak":true},{"text":"Tu m’as rassuré, tu as fortifié mon âme.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Tous les rois de la terre te loueront, ô Éternel!","poem":1},{"lineBreak":true},{"text":"En entendant les paroles de ta bouche;","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Ils célébreront les voies de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Car la gloire de l’Éternel est grande.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"L’Éternel est élevé: il voit les humbles,","poem":1},{"lineBreak":true},{"text":"Et il reconnaît de loin les orgueilleux.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Quand je marche au milieu de la détresse, tu me rends la vie,","poem":1},{"lineBreak":true},{"text":"Tu étends ta main sur la colère de mes ennemis,","poem":1},{"lineBreak":true},{"text":"Et ta droite me sauve.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"L’Éternel agira en ma faveur.","poem":1},{"lineBreak":true},{"text":"Éternel, ta bonté dure toujours,","poem":1},{"lineBreak":true},{"text":"N’abandonne pas les œuvres de tes mains!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/138.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/139.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/137.json","previousChapterAudioLinks":{},"numberOfVerses":8}