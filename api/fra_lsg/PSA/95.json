{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":95,"content":[{"type":"verse","number":1,"content":[{"text":"Venez, chantons avec allégresse à l’Éternel!","poem":1},{"lineBreak":true},{"text":"Poussons des cris de joie vers le rocher de notre salut.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Allons au-devant de lui avec des louanges,","poem":1},{"lineBreak":true},{"text":"Faisons retentir des cantiques en son honneur!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Car l’Éternel est un grand Dieu,","poem":1},{"lineBreak":true},{"text":"Il est un grand roi au-dessus de tous les dieux.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Il tient dans sa main les profondeurs de la terre,","poem":1},{"lineBreak":true},{"text":"Et les sommets des montagnes sont à lui.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"La mer est à lui, c’est lui qui l’a faite;","poem":1},{"lineBreak":true},{"text":"La terre aussi, ses mains l’ont formée.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Venez, prosternons-nous et humilions-nous,","poem":1},{"lineBreak":true},{"text":"Fléchissons le genou devant l’Éternel, notre créateur!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Car il est notre Dieu,","poem":1},{"lineBreak":true},{"text":"Et nous sommes le peuple de son pâturage,","poem":1},{"lineBreak":true},{"text":"Le troupeau que sa main conduit…","poem":1},{"lineBreak":true},{"text":"Oh! Si vous pouviez écouter aujourd’hui sa voix!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"N’endurcissez pas votre cœur, comme à Meriba,","poem":1},{"lineBreak":true},{"text":"Comme à la journée de Massa, dans le désert,","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Où vos pères me tentèrent,","poem":1},{"lineBreak":true},{"text":"M’éprouvèrent, quoiqu’ils vissent mes œuvres.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Pendant quarante ans j’eus cette race en dégoût,","poem":1},{"lineBreak":true},{"text":"Et je dis: C’est un peuple dont le cœur est égaré;","poem":1},{"lineBreak":true},{"text":"Ils ne connaissent pas mes voies.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Aussi je jurai dans ma colère:","poem":1},{"lineBreak":true},{"text":"Ils n’entreront pas dans mon repos!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/95.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/96.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/94.json","previousChapterAudioLinks":{},"numberOfVerses":11}