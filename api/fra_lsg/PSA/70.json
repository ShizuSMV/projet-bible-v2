{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":70,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. De David. Pour souvenir.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"O Dieu, hâte-toi de me délivrer!","poem":1},{"lineBreak":true},{"text":"Éternel, hâte-toi de me secourir!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Qu’ils soient honteux et confus, ceux qui en veulent à ma vie!","poem":1},{"lineBreak":true},{"text":"Qu’ils reculent et rougissent, ceux qui désirent ma perte!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Qu’ils retournent en arrière par l’effet de leur honte,","poem":1},{"lineBreak":true},{"text":"Ceux qui disent: Ah! Ah!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Que tous ceux qui te cherchent","poem":1},{"lineBreak":true},{"text":"Soient dans l’allégresse et se réjouissent en toi!","poem":1},{"lineBreak":true},{"text":"Que ceux qui aiment ton salut","poem":1},{"lineBreak":true},{"text":"Disent sans cesse: Exalté soit Dieu!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Moi, je suis pauvre et indigent:","poem":1},{"lineBreak":true},{"text":"O Dieu, hâte-toi en ma faveur!","poem":1},{"lineBreak":true},{"text":"Tu es mon aide et mon libérateur:","poem":1},{"lineBreak":true},{"text":"Éternel, ne tarde pas!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/70.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/71.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/69.json","previousChapterAudioLinks":{},"numberOfVerses":6}