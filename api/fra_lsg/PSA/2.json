{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":2,"content":[{"type":"verse","number":1,"content":[{"text":"Pourquoi ce tumulte parmi les nations,","poem":1},{"lineBreak":true},{"text":"Ces vaines pensées parmi les peuples?","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Pourquoi les rois de la terre se soulèvent-ils","poem":1},{"lineBreak":true},{"text":"Et les princes se liguent-ils avec eux","poem":1},{"lineBreak":true},{"text":"Contre l’Éternel et contre son oint?","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Brisons leurs liens,","poem":1},{"lineBreak":true},{"text":"Délivrons-nous de leurs chaînes!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Celui qui siège dans les cieux rit,","poem":1},{"lineBreak":true},{"text":"Le Seigneur se moque d’eux.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Puis il leur parle dans sa colère,","poem":1},{"lineBreak":true},{"text":"Il les épouvante dans sa fureur:","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"C’est moi qui ai oint mon roi","poem":1},{"lineBreak":true},{"text":"Sur Sion, ma montagne sainte!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je publierai le décret;","poem":1},{"lineBreak":true},{"text":"L’Éternel m’a dit: Tu es mon fils!","poem":1},{"lineBreak":true},{"text":"Je t’ai engendré aujourd’hui.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Demande-moi et je te donnerai les nations pour héritage,","poem":1},{"lineBreak":true},{"text":"Les extrémités de la terre pour possession;","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Tu les briseras avec une verge de fer,","poem":1},{"lineBreak":true},{"text":"Tu les briseras comme le vase d’un potier.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Et maintenant, rois, conduisez-vous avec sagesse!","poem":1},{"lineBreak":true},{"text":"Juges de la terre, recevez instruction!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Servez l’Éternel avec crainte,","poem":1},{"lineBreak":true},{"text":"Et réjouissez-vous avec tremblement.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Baisez le fils, de peur qu’il ne s’irrite,","poem":1},{"lineBreak":true},{"text":"Et que vous ne périssiez dans votre voie,","poem":1},{"lineBreak":true},{"text":"Car sa colère est prompte à s’enflammer.","poem":1},{"lineBreak":true},{"text":"Heureux tous ceux qui se confient en lui!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/2.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/3.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/1.json","previousChapterAudioLinks":{},"numberOfVerses":12}