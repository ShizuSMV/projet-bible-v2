{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":82,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume d’Asaph.","poem":1},{"lineBreak":true},{"text":"Dieu se tient dans l’assemblée de Dieu;","poem":1},{"lineBreak":true},{"text":"Il juge au milieu des dieux.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Jusques à quand jugerez-vous avec iniquité,","poem":1},{"lineBreak":true},{"text":"Et aurez-vous égard à la personne des méchants? — Pause.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Rendez justice au faible et à l’orphelin,","poem":1},{"lineBreak":true},{"text":"Faites droit au malheureux et au pauvre,","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Sauvez le misérable et l’indigent,","poem":1},{"lineBreak":true},{"text":"Délivrez-les de la main des méchants.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Ils n’ont ni savoir ni intelligence,","poem":1},{"lineBreak":true},{"text":"Ils marchent dans les ténèbres;","poem":1},{"lineBreak":true},{"text":"Tous les fondements de la terre sont ébranlés.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"J’avais dit: Vous êtes des dieux,","poem":1},{"lineBreak":true},{"text":"Vous êtes tous des fils du Très-Haut.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Cependant vous mourrez comme des hommes,","poem":1},{"lineBreak":true},{"text":"Vous tomberez comme un prince quelconque.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Lève-toi, ô Dieu, juge la terre!","poem":1},{"lineBreak":true},{"text":"Car toutes les nations t’appartiennent.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/82.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/83.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/81.json","previousChapterAudioLinks":{},"numberOfVerses":8}