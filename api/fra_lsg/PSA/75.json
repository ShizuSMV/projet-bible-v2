{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":75,"content":[{"type":"verse","number":1,"content":["Au chef des chantres. “Ne détruis pas.” Psaume d’Asaph. Cantique."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Nous te louons, ô Dieu! Nous te louons;","poem":1},{"lineBreak":true},{"text":"Ton nom est dans nos bouches;","poem":1},{"lineBreak":true},{"text":"Nous publions tes merveilles.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Au temps que j’aurai fixé,","poem":1},{"lineBreak":true},{"text":"Je jugerai avec droiture.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"La terre tremble avec tous ceux qui l’habitent:","poem":1},{"lineBreak":true},{"text":"Moi, j’affermis ses colonnes. — Pause.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Je dis à ceux qui se glorifient: Ne vous glorifiez pas!","poem":1},{"lineBreak":true},{"text":"Et aux méchants: N’élevez pas la tête!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"N’élevez pas si haut votre tête,","poem":1},{"lineBreak":true},{"text":"Ne parlez pas avec tant d’arrogance!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Car ce n’est ni de l’orient, ni de l’occident,","poem":1},{"lineBreak":true},{"text":"Ni du désert, que vient l’élévation.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Mais Dieu est celui qui juge:","poem":1},{"lineBreak":true},{"text":"Il abaisse l’un, et il élève l’autre.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Il y a dans la main de l’Éternel une coupe,","poem":1},{"lineBreak":true},{"text":"Où fermente un vin plein de mélange,","poem":1},{"lineBreak":true},{"text":"Et il en verse:","poem":1},{"lineBreak":true},{"text":"Tous les méchants de la terre sucent, boivent jusqu’à la lie.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Je publierai ces choses à jamais;","poem":1},{"lineBreak":true},{"text":"Je chanterai en l’honneur du Dieu de Jacob.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Et j’abattrai toutes les forces des méchants;","poem":1},{"lineBreak":true},{"text":"Les forces du juste seront élevées.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/75.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/76.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/74.json","previousChapterAudioLinks":{},"numberOfVerses":11}