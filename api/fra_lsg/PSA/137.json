{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":137,"content":[{"type":"verse","number":1,"content":[{"text":"Sur les bords des fleuves de Babylone,","poem":1},{"lineBreak":true},{"text":"Nous étions assis et nous pleurions,","poem":1},{"lineBreak":true},{"text":"En nous souvenant de Sion.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Aux saules de la contrée","poem":1},{"lineBreak":true},{"text":"Nous avions suspendu nos harpes.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Là, nos vainqueurs nous demandaient des chants,","poem":1},{"lineBreak":true},{"text":"Et nos oppresseurs de la joie:","poem":1},{"lineBreak":true},{"text":"Chantez-nous quelques-uns des cantiques de Sion!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Comment chanterions-nous les cantiques de l’Éternel","poem":1},{"lineBreak":true},{"text":"Sur une terre étrangère?","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Si je t’oublie, Jérusalem,","poem":1},{"lineBreak":true},{"text":"Que ma droite m’oublie!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Que ma langue s’attache à mon palais,","poem":1},{"lineBreak":true},{"text":"Si je ne me souviens de toi,","poem":1},{"lineBreak":true},{"text":"Si je ne fais de Jérusalem","poem":1},{"lineBreak":true},{"text":"Le principal sujet de ma joie!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Éternel, souviens-toi des enfants d’Édom,","poem":1},{"lineBreak":true},{"text":"Qui, dans la journée de Jérusalem,","poem":1},{"lineBreak":true},{"text":"Disaient: Rasez, rasez","poem":1},{"lineBreak":true},{"text":"Jusqu’à ses fondements!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Fille de Babylone, la dévastée,","poem":1},{"lineBreak":true},{"text":"Heureux qui te rend la pareille,","poem":1},{"lineBreak":true},{"text":"Le mal que tu nous as fait!","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Heureux qui saisit tes enfants,","poem":1},{"lineBreak":true},{"text":"Et les écrase sur le roc!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/137.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/138.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/136.json","previousChapterAudioLinks":{},"numberOfVerses":9}