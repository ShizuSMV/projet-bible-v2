{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":30,"content":[{"type":"verse","number":1,"content":["Psaume. Cantique pour la dédicace de la maison. De David."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Je t’exalte, ô Éternel, car tu m’as relevé,","poem":1},{"lineBreak":true},{"text":"Tu n’as pas voulu que mes ennemis se réjouissent à mon sujet.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Éternel, mon Dieu!","poem":1},{"lineBreak":true},{"text":"J’ai crié à toi, et tu m’as guéri.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Éternel! Tu as fait remonter mon âme du séjour des morts,","poem":1},{"lineBreak":true},{"text":"Tu m’as fait revivre loin de ceux qui descendent dans la fosse.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Chantez à l’Éternel, vous qui l’aimez,","poem":1},{"lineBreak":true},{"text":"Célébrez par vos louanges sa sainteté!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Car sa colère dure un instant,","poem":1},{"lineBreak":true},{"text":"Mais sa grâce toute la vie;","poem":1},{"lineBreak":true},{"text":"Le soir arrivent les pleurs,","poem":1},{"lineBreak":true},{"text":"Et le matin l’allégresse.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je disais dans ma sécurité:","poem":1},{"lineBreak":true},{"text":"Je ne chancellerai jamais!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Éternel! Par ta grâce tu avais affermi ma montagne…","poem":1},{"lineBreak":true},{"text":"Tu cachas ta face, et je fus troublé.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Éternel! J’ai crié à toi,","poem":1},{"lineBreak":true},{"text":"J’ai imploré l’Éternel:","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Que gagnes-tu à verser mon sang,","poem":1},{"lineBreak":true},{"text":"A me faire descendre dans la fosse?","poem":1},{"lineBreak":true},{"text":"La poussière a-t-elle pour toi des louanges?","poem":1},{"lineBreak":true},{"text":"Raconte-t-elle ta fidélité?","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Écoute, Éternel, aie pitié de moi!","poem":1},{"lineBreak":true},{"text":"Éternel, secours-moi!","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Et tu as changé mes lamentations en allégresse,","poem":1},{"lineBreak":true},{"text":"Tu as délié mon sac, et tu m’as ceint de joie,","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Afin que mon cœur te chante et ne soit pas muet.","poem":1},{"lineBreak":true},{"text":"Éternel, mon Dieu! Je te louerai toujours.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/30.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/31.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/29.json","previousChapterAudioLinks":{},"numberOfVerses":13}