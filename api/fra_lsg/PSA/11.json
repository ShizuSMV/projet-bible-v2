{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":11,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. De David.","poem":1},{"lineBreak":true},{"text":"C’est en l’Éternel que je cherche un refuge.","poem":1},{"lineBreak":true},{"text":"Comment pouvez-vous me dire:","poem":1},{"lineBreak":true},{"text":"Fuis dans vos montagnes, comme un oiseau?","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Car voici, les méchants bandent l’arc,","poem":1},{"lineBreak":true},{"text":"Ils ajustent leur flèche sur la corde,","poem":1},{"lineBreak":true},{"text":"Pour tirer dans l’ombre sur ceux dont le cœur est droit.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Quand les fondements sont renversés,","poem":1},{"lineBreak":true},{"text":"Le juste, que ferait-il?","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"L’Éternel est dans son saint temple,","poem":1},{"lineBreak":true},{"text":"L’Éternel a son trône dans les cieux;","poem":1},{"lineBreak":true},{"text":"Ses yeux regardent,","poem":1},{"lineBreak":true},{"text":"Ses paupières sondent les fils de l’homme.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"L’Éternel sonde le juste;","poem":1},{"lineBreak":true},{"text":"Il hait le méchant et celui qui se plaît à la violence.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il fait pleuvoir sur les méchants","poem":1},{"lineBreak":true},{"text":"Des charbons, du feu et du soufre;","poem":1},{"lineBreak":true},{"text":"Un vent brûlant, c’est le calice qu’ils ont en partage.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Car l’Éternel est juste, il aime la justice;","poem":1},{"lineBreak":true},{"text":"Les hommes droits contemplent sa face.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/11.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/12.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/10.json","previousChapterAudioLinks":{},"numberOfVerses":7}