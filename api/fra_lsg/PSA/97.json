{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":97,"content":[{"type":"verse","number":1,"content":[{"text":"L’Éternel règne: que la terre soit dans l’allégresse,","poem":1},{"lineBreak":true},{"text":"Que les îles nombreuses se réjouissent!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Les nuages et l’obscurité l’environnent,","poem":1},{"lineBreak":true},{"text":"La justice et l’équité sont la base de son trône.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Le feu marche devant lui,","poem":1},{"lineBreak":true},{"text":"Et embrase à l’entour ses adversaires.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Ses éclairs illuminent le monde,","poem":1},{"lineBreak":true},{"text":"La terre le voit et tremble;","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Les montagnes se fondent comme la cire devant l’Éternel,","poem":1},{"lineBreak":true},{"text":"Devant le Seigneur de toute la terre.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Les cieux publient sa justice,","poem":1},{"lineBreak":true},{"text":"Et tous les peuples voient sa gloire.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Ils sont confus, tous ceux qui servent les images,","poem":1},{"lineBreak":true},{"text":"Qui se font gloire des idoles.","poem":1},{"lineBreak":true},{"text":"Tous les dieux se prosternent devant lui.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Sion l’entend et se réjouit,","poem":1},{"lineBreak":true},{"text":"Les filles de Juda sont dans l’allégresse,","poem":1},{"lineBreak":true},{"text":"A cause de tes jugements, ô Éternel!","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Car toi, Éternel! Tu es le Très-Haut sur toute la terre,","poem":1},{"lineBreak":true},{"text":"Tu es souverainement élevé au-dessus de tous les dieux.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Vous qui aimez l’Éternel, haïssez le mal!","poem":1},{"lineBreak":true},{"text":"Il garde les âmes de ses fidèles,","poem":1},{"lineBreak":true},{"text":"Il les délivre de la main des méchants.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"La lumière est semée pour le juste,","poem":1},{"lineBreak":true},{"text":"Et la joie pour ceux dont le cœur est droit.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Justes, réjouissez-vous en l’Éternel,","poem":1},{"lineBreak":true},{"text":"Et célébrez par vos louanges sa sainteté!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/97.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/98.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/96.json","previousChapterAudioLinks":{},"numberOfVerses":12}