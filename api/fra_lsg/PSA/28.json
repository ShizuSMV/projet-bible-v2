{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":28,"content":[{"type":"verse","number":1,"content":[{"text":"De David.","poem":1},{"lineBreak":true},{"text":"Éternel! C’est à toi que je crie.","poem":1},{"lineBreak":true},{"text":"Mon rocher! Ne reste pas sourd à ma voix,","poem":1},{"lineBreak":true},{"text":"De peur que, si tu t’éloignes sans me répondre,","poem":1},{"lineBreak":true},{"text":"Je ne sois semblable à ceux qui descendent dans la fosse.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Écoute la voix de mes supplications, quand je crie à toi,","poem":1},{"lineBreak":true},{"text":"Quand j’élève mes mains vers ton sanctuaire.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Ne m’emporte pas avec les méchants et les hommes iniques,","poem":1},{"lineBreak":true},{"text":"Qui parlent de paix à leur prochain et qui ont la malice dans le cœur.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Rends-leur selon leurs œuvres et selon la malice de leurs actions,","poem":1},{"lineBreak":true},{"text":"Rends-leur selon l’ouvrage de leurs mains;","poem":1},{"lineBreak":true},{"text":"Donne-leur le salaire qu’ils méritent.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Car ils ne sont pas attentifs aux œuvres de l’Éternel,","poem":1},{"lineBreak":true},{"text":"A l’ouvrage de ses mains.","poem":1},{"lineBreak":true},{"text":"Qu’il les renverse et ne les relève point!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Béni soit l’Éternel!","poem":1},{"lineBreak":true},{"text":"Car il exauce la voix de mes supplications.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"L’Éternel est ma force et mon bouclier;","poem":1},{"lineBreak":true},{"text":"En lui mon cœur se confie, et je suis secouru;","poem":1},{"lineBreak":true},{"text":"J’ai de l’allégresse dans le cœur,","poem":1},{"lineBreak":true},{"text":"Et je le loue par mes chants.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"L’Éternel est la force de son peuple,","poem":1},{"lineBreak":true},{"text":"Il est le rocher des délivrances de son oint.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Sauve ton peuple et bénis ton héritage!","poem":1},{"lineBreak":true},{"text":"Sois leur berger et leur soutien pour toujours!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/28.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/29.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/27.json","previousChapterAudioLinks":{},"numberOfVerses":9}