{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":143,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume de David.","poem":1},{"lineBreak":true},{"text":"Éternel, écoute ma prière, prête l’oreille à mes supplications!","poem":1},{"lineBreak":true},{"text":"Exauce-moi dans ta fidélité, dans ta justice!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"N’entre pas en jugement avec ton serviteur!","poem":1},{"lineBreak":true},{"text":"Car aucun vivant n’est juste devant toi.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"L’ennemi poursuit mon âme,","poem":1},{"lineBreak":true},{"text":"Il foule à terre ma vie;","poem":1},{"lineBreak":true},{"text":"Il me fait habiter dans les ténèbres,","poem":1},{"lineBreak":true},{"text":"Comme ceux qui sont morts depuis longtemps.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Mon esprit est abattu au-dedans de moi,","poem":1},{"lineBreak":true},{"text":"Mon cœur est troublé dans mon sein.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Je me souviens des jours d’autrefois,","poem":1},{"lineBreak":true},{"text":"Je médite sur toutes tes œuvres,","poem":1},{"lineBreak":true},{"text":"Je réfléchis sur l’ouvrage de tes mains.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"J’étends mes mains vers toi;","poem":1},{"lineBreak":true},{"text":"Mon âme soupire après toi, comme une terre desséchée. — Pause.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Hâte-toi de m’exaucer, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Mon esprit se consume.","poem":1},{"lineBreak":true},{"text":"Ne me cache pas ta face!","poem":1},{"lineBreak":true},{"text":"Je serais semblable à ceux qui descendent dans la fosse.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Fais-moi dès le matin entendre ta bonté!","poem":1},{"lineBreak":true},{"text":"Car je me confie en toi.","poem":1},{"lineBreak":true},{"text":"Fais-moi connaître le chemin où je dois marcher!","poem":1},{"lineBreak":true},{"text":"Car j’élève à toi mon âme.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Délivre-moi de mes ennemis, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Auprès de toi je cherche un refuge.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Enseigne-moi à faire ta volonté!","poem":1},{"lineBreak":true},{"text":"Car tu es mon Dieu.","poem":1},{"lineBreak":true},{"text":"Que ton bon esprit me conduise sur la voie droite!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"A cause de ton nom, Éternel, rends-moi la vie!","poem":1},{"lineBreak":true},{"text":"Dans ta justice, retire mon âme de la détresse!","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Dans ta bonté, anéantis mes ennemis,","poem":1},{"lineBreak":true},{"text":"Et fais périr tous les oppresseurs de mon âme!","poem":1},{"lineBreak":true},{"text":"Car je suis ton serviteur.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/143.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/144.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/142.json","previousChapterAudioLinks":{},"numberOfVerses":12}