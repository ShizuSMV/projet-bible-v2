{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":113,"content":[{"type":"verse","number":1,"content":[{"text":"Louez l’Éternel!","poem":1},{"lineBreak":true},{"text":"Serviteurs de l’Éternel, louez,","poem":1},{"lineBreak":true},{"text":"Louez le nom de l’Éternel!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Que le nom de l’Éternel soit béni,","poem":1},{"lineBreak":true},{"text":"Dès maintenant et à jamais!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Du lever du soleil jusqu’à son couchant,","poem":1},{"lineBreak":true},{"text":"Que le nom de l’Éternel soit célébré!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"L’Éternel est élevé au-dessus de toutes les nations,","poem":1},{"lineBreak":true},{"text":"Sa gloire est au-dessus des cieux.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Qui est semblable à l’Éternel, notre Dieu?","poem":1},{"lineBreak":true},{"text":"Il a sa demeure en haut;","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il abaisse les regards","poem":1},{"lineBreak":true},{"text":"Sur les cieux et sur la terre.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"De la poussière il retire le pauvre,","poem":1},{"lineBreak":true},{"text":"Du fumier il relève l’indigent,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Pour les faire asseoir avec les grands,","poem":1},{"lineBreak":true},{"text":"Avec les grands de son peuple.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Il donne une maison à celle qui était stérile,","poem":1},{"lineBreak":true},{"text":"Il en fait une mère joyeuse au milieu de ses enfants.","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/113.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/114.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/112.json","previousChapterAudioLinks":{},"numberOfVerses":9}