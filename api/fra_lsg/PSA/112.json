{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":112,"content":[{"type":"verse","number":1,"content":[{"text":"Louez l’Éternel!","poem":1},{"lineBreak":true},{"text":"Heureux l’homme qui craint l’Éternel,","poem":1},{"lineBreak":true},{"text":"Qui trouve un grand plaisir à ses commandements.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Sa postérité sera puissante sur la terre,","poem":1},{"lineBreak":true},{"text":"La génération des hommes droits sera bénie.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Il a dans sa maison bien-être et richesse,","poem":1},{"lineBreak":true},{"text":"Et sa justice subsiste à jamais.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"La lumière se lève dans les ténèbres pour les hommes droits,","poem":1},{"lineBreak":true},{"text":"Pour celui qui est miséricordieux, compatissant et juste.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Heureux l’homme qui exerce la miséricorde et qui prête,","poem":1},{"lineBreak":true},{"text":"Qui règle ses actions d’après la justice!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Car il ne chancelle jamais;","poem":1},{"lineBreak":true},{"text":"La mémoire du juste dure toujours.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Il ne craint point les mauvaises nouvelles;","poem":1},{"lineBreak":true},{"text":"Son cœur est ferme, confiant en l’Éternel.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Son cœur est affermi; il n’a point de crainte,","poem":1},{"lineBreak":true},{"text":"Jusqu’à ce qu’il mette son plaisir à regarder ses adversaires.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Il fait des largesses, il donne aux indigents;","poem":1},{"lineBreak":true},{"text":"Sa justice subsiste à jamais;","poem":1},{"lineBreak":true},{"text":"Sa tête s’élève avec gloire,","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Le méchant le voit et s’irrite,","poem":1},{"lineBreak":true},{"text":"Il grince les dents et se consume;","poem":1},{"lineBreak":true},{"text":"Les désirs des méchants périssent.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/112.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/113.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/111.json","previousChapterAudioLinks":{},"numberOfVerses":10}