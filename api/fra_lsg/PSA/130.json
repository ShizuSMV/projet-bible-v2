{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":130,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés.","poem":1},{"lineBreak":true},{"text":"Du fond de l’abîme je t’invoque, ô Éternel!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Seigneur, écoute ma voix!","poem":1},{"lineBreak":true},{"text":"Que tes oreilles soient attentives","poem":1},{"lineBreak":true},{"text":"A la voix de mes supplications!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Si tu gardais le souvenir des iniquités,","poem":1},{"lineBreak":true},{"text":"Éternel, Seigneur, qui pourrait subsister?","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Mais le pardon se trouve auprès de toi,","poem":1},{"lineBreak":true},{"text":"Afin qu’on te craigne.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"J’espère en l’Éternel, mon âme espère,","poem":1},{"lineBreak":true},{"text":"Et j’attends sa promesse.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Mon âme compte sur le Seigneur,","poem":1},{"lineBreak":true},{"text":"Plus que les gardes ne comptent sur le matin,","poem":1},{"lineBreak":true},{"text":"Que les gardes ne comptent sur le matin.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Israël, mets ton espoir en l’Éternel!","poem":1},{"lineBreak":true},{"text":"Car la miséricorde est auprès de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Et la rédemption est auprès de lui en abondance.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"C’est lui qui rachètera Israël","poem":1},{"lineBreak":true},{"text":"De toutes ses iniquités.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/130.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/131.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/129.json","previousChapterAudioLinks":{},"numberOfVerses":8}