{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":41,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Heureux celui qui s’intéresse au pauvre!","poem":1},{"lineBreak":true},{"text":"Au jour du malheur l’Éternel le délivre;","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"L’Éternel le garde et lui conserve la vie.","poem":1},{"lineBreak":true},{"text":"Il est heureux sur la terre,","poem":1},{"lineBreak":true},{"text":"Et tu ne le livres pas au bon plaisir de ses ennemis.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"L’Éternel le soutient sur son lit de douleur;","poem":1},{"lineBreak":true},{"text":"Tu le soulages dans toutes ses maladies.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Je dis: Éternel, aie pitié de moi!","poem":1},{"lineBreak":true},{"text":"Guéris mon âme! Car j’ai péché contre toi.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Mes ennemis disent méchamment de moi:","poem":1},{"lineBreak":true},{"text":"Quand mourra-t-il? Quand périra son nom?","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Si quelqu’un vient me voir, il prend un langage faux,","poem":1},{"lineBreak":true},{"text":"Il recueille des sujets de médire;","poem":1},{"lineBreak":true},{"text":"Il s’en va, et il parle au-dehors.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Tous mes ennemis chuchotent entre eux contre moi;","poem":1},{"lineBreak":true},{"text":"Ils pensent que mon malheur causera ma ruine:","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Il est dangereusement atteint,","poem":1},{"lineBreak":true},{"text":"Le voilà couché, il ne se relèvera pas!","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Celui-là même avec qui j’étais en paix,","poem":1},{"lineBreak":true},{"text":"Qui avait ma confiance et qui mangeait mon pain,","poem":1},{"lineBreak":true},{"text":"Lève le talon contre moi.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Toi, Éternel, aie pitié de moi et rétablis-moi!","poem":1},{"lineBreak":true},{"text":"Et je leur rendrai ce qui leur est dû.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Je connaîtrai que tu m’aimes,","poem":1},{"lineBreak":true},{"text":"Si mon ennemi ne triomphe pas de moi.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Tu m’as soutenu à cause de mon intégrité,","poem":1},{"lineBreak":true},{"text":"Et tu m’as placé pour toujours en ta présence.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Béni soit l’Éternel, le Dieu d’Israël, d’éternité en éternité! Amen! Amen!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/41.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/42.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/40.json","previousChapterAudioLinks":{},"numberOfVerses":14}