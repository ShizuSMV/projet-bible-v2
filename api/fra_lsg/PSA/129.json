{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":129,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés.","poem":1},{"lineBreak":true},{"text":"Ils m’ont assez opprimé dès ma jeunesse,","poem":1},{"lineBreak":true},{"text":"Qu’Israël le dise!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Ils m’ont assez opprimé dès ma jeunesse,","poem":1},{"lineBreak":true},{"text":"Mais ils ne m’ont pas vaincu.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Des laboureurs ont labouré mon dos,","poem":1},{"lineBreak":true},{"text":"Ils y ont tracé de longs sillons.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"L’Éternel est juste:","poem":1},{"lineBreak":true},{"text":"Il a coupé les cordes des méchants.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Qu’ils soient confondus et qu’ils reculent,","poem":1},{"lineBreak":true},{"text":"Tous ceux qui haïssent Sion!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Qu’ils soient comme l’herbe des toits,","poem":1},{"lineBreak":true},{"text":"Qui sèche avant qu’on l’arrache!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Le moissonneur n’en remplit point sa main,","poem":1},{"lineBreak":true},{"text":"Celui qui lie les gerbes n’en charge point son bras,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Et les passants ne disent point:","poem":1},{"lineBreak":true},{"text":"Que la bénédiction de l’Éternel soit sur vous!","poem":1},{"lineBreak":true},{"text":"Nous vous bénissons au nom de l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/129.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/130.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/128.json","previousChapterAudioLinks":{},"numberOfVerses":8}