{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":52,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Cantique de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"A l’occasion du rapport que Doëg, l’Édomite, vint faire à Saül, en lui disant: David s’est rendu dans la maison d’Achimélec.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Pourquoi te glorifies-tu de ta méchanceté, tyran?","poem":1},{"lineBreak":true},{"text":"La bonté de Dieu subsiste toujours.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Ta langue n’invente que malice,","poem":1},{"lineBreak":true},{"text":"Comme un rasoir affilé, fourbe que tu es!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Tu aimes le mal plutôt que le bien,","poem":1},{"lineBreak":true},{"text":"Le mensonge plutôt que la droiture. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Tu aimes toutes les paroles de destruction,","poem":1},{"lineBreak":true},{"text":"Langue trompeuse!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Aussi Dieu t’abattra pour toujours,","poem":1},{"lineBreak":true},{"text":"Il te saisira et t’enlèvera de ta tente;","poem":1},{"lineBreak":true},{"text":"Il te déracinera de la terre des vivants. — Pause.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Les justes le verront, et auront de la crainte,","poem":1},{"lineBreak":true},{"text":"Et ils feront de lui le sujet de leurs moqueries:","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Voilà l’homme qui ne prenait point Dieu pour protecteur,","poem":1},{"lineBreak":true},{"text":"Mais qui se confiait en ses grandes richesses,","poem":1},{"lineBreak":true},{"text":"Et qui triomphait dans sa malice!","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Et moi, je suis dans la maison de Dieu comme un olivier verdoyant,","poem":1},{"lineBreak":true},{"text":"Je me confie dans la bonté de Dieu, éternellement et à jamais.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Je te louerai toujours, parce que tu as agi;","poem":1},{"lineBreak":true},{"text":"Et je veux espérer en ton nom, parce qu’il est favorable,","poem":1},{"lineBreak":true},{"text":"En présence de tes fidèles.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/52.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/53.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/51.json","previousChapterAudioLinks":{},"numberOfVerses":11}