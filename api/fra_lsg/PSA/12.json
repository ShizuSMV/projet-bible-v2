{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":12,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Sur la harpe à huit cordes. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Sauve, Éternel! Car les hommes pieux s’en vont,","poem":1},{"lineBreak":true},{"text":"Les fidèles disparaissent parmi les fils de l’homme.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"On se dit des faussetés les uns aux autres,","poem":1},{"lineBreak":true},{"text":"On a sur les lèvres des choses flatteuses,","poem":1},{"lineBreak":true},{"text":"On parle avec un cœur double.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Que l’Éternel extermine toutes les lèvres flatteuses,","poem":1},{"lineBreak":true},{"text":"La langue qui discourt avec arrogance,","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Ceux qui disent: Nous sommes puissants par notre langue,","poem":1},{"lineBreak":true},{"text":"Nous avons nos lèvres avec nous;","poem":1},{"lineBreak":true},{"text":"Qui serait notre maître?","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Parce que les malheureux sont opprimés et que les pauvres gémissent,","poem":1},{"lineBreak":true},{"text":"Maintenant, dit l’Éternel, je me lève,","poem":1},{"lineBreak":true},{"text":"J’apporte le salut à ceux contre qui l’on souffle.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Les paroles de l’Éternel sont des paroles pures,","poem":1},{"lineBreak":true},{"text":"Un argent éprouvé sur terre au creuset,","poem":1},{"lineBreak":true},{"text":"Et sept fois épuré.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Toi, Éternel! Tu les garderas,","poem":1},{"lineBreak":true},{"text":"Tu les préserveras de cette race à jamais.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Les méchants se promènent de toutes parts,","poem":1},{"lineBreak":true},{"text":"Quand la bassesse règne parmi les fils de l’homme.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/11.json","previousChapterAudioLinks":{},"numberOfVerses":9}