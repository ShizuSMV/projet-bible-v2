{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":43,"content":[{"type":"verse","number":1,"content":[{"text":"Rends-moi justice, ô Dieu, défends ma cause contre une nation infidèle!","poem":1},{"lineBreak":true},{"text":"Délivre-moi des hommes de fraude et d’iniquité!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Toi, mon Dieu protecteur, pourquoi me repousses-tu?","poem":1},{"lineBreak":true},{"text":"Pourquoi dois-je marcher dans la tristesse,","poem":1},{"lineBreak":true},{"text":"Sous l’oppression de l’ennemi?","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Envoie ta lumière et ta fidélité!","poem":1},{"lineBreak":true},{"text":"Qu’elles me guident,","poem":1},{"lineBreak":true},{"text":"Qu’elles me conduisent à ta montagne sainte et à tes demeures!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"J’irai vers l’autel de Dieu, de Dieu, ma joie et mon allégresse,","poem":1},{"lineBreak":true},{"text":"Et je te célébrerai sur la harpe, ô Dieu, mon Dieu!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Pourquoi t’abats-tu, mon âme, et gémis-tu au-dedans de moi?","poem":1},{"lineBreak":true},{"text":"Espère en Dieu, car je le louerai encore;","poem":1},{"lineBreak":true},{"text":"Il est mon salut et mon Dieu.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/43.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/44.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/42.json","previousChapterAudioLinks":{},"numberOfVerses":5}