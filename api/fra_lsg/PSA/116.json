{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":116,"content":[{"type":"verse","number":1,"content":[{"text":"J’aime l’Éternel, car il entend","poem":1},{"lineBreak":true},{"text":"Ma voix, mes supplications;","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Car il a penché son oreille vers moi;","poem":1},{"lineBreak":true},{"text":"Et je l’invoquerai toute ma vie.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Les liens de la mort m’avaient environné,","poem":1},{"lineBreak":true},{"text":"Et les angoisses du sépulcre m’avaient saisi;","poem":1},{"lineBreak":true},{"text":"J’étais en proie à la détresse et à la douleur.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Mais j’invoquai le nom de l’Éternel:","poem":1},{"lineBreak":true},{"text":"O Éternel, sauve mon âme!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"L’Éternel est miséricordieux et juste,","poem":1},{"lineBreak":true},{"text":"Notre Dieu est plein de compassion;","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"L’Éternel garde les simples;","poem":1},{"lineBreak":true},{"text":"J’étais malheureux, et il m’a sauvé.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Mon âme, retourne à ton repos,","poem":1},{"lineBreak":true},{"text":"Car l’Éternel t’a fait du bien.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Oui, tu as délivré mon âme de la mort,","poem":1},{"lineBreak":true},{"text":"Mes yeux des larmes,","poem":1},{"lineBreak":true},{"text":"Mes pieds de la chute.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Je marcherai devant l’Éternel,","poem":1},{"lineBreak":true},{"text":"Sur la terre des vivants.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"J’avais confiance, lorsque je disais: Je suis bien malheureux!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Je disais dans mon angoisse:","poem":1},{"lineBreak":true},{"text":"Tout homme est trompeur.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Comment rendrai-je à l’Éternel","poem":1},{"lineBreak":true},{"text":"Tous ses bienfaits envers moi?","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"J’élèverai la coupe des délivrances,","poem":1},{"lineBreak":true},{"text":"Et j’invoquerai le nom de l’Éternel;","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"J’accomplirai mes vœux envers l’Éternel,","poem":1},{"lineBreak":true},{"text":"En présence de tout son peuple.","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Elle a du prix aux yeux de l’Éternel,","poem":1},{"lineBreak":true},{"text":"La mort de ceux qui l’aiment.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Écoute-moi, ô Éternel! Car je suis ton serviteur,","poem":1},{"lineBreak":true},{"text":"Ton serviteur, fils de ta servante.","poem":1},{"lineBreak":true},{"text":"Tu as détaché mes liens.","poem":1}]},{"type":"verse","number":17,"content":[{"lineBreak":true},{"text":"Je t’offrirai un sacrifice d’actions de grâces,","poem":1},{"lineBreak":true},{"text":"Et j’invoquerai le nom de l’Éternel;","poem":1}]},{"type":"verse","number":18,"content":[{"lineBreak":true},{"text":"J’accomplirai mes vœux envers l’Éternel,","poem":1},{"lineBreak":true},{"text":"En présence de tout son peuple,","poem":1}]},{"type":"verse","number":19,"content":[{"lineBreak":true},{"text":"Dans les parvis de la maison de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Au milieu de toi, Jérusalem!","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/116.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/117.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/115.json","previousChapterAudioLinks":{},"numberOfVerses":19}