{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":121,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés.","poem":1},{"lineBreak":true},{"text":"Je lève mes yeux vers les montagnes…","poem":1},{"lineBreak":true},{"text":"D’où me viendra le secours?","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Le secours me vient de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Qui a fait les cieux et la terre.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Il ne permettra point que ton pied chancelle;","poem":1},{"lineBreak":true},{"text":"Celui qui te garde ne sommeillera point.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Voici, il ne sommeille ni ne dort,","poem":1},{"lineBreak":true},{"text":"Celui qui garde Israël.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"L’Éternel est celui qui te garde,","poem":1},{"lineBreak":true},{"text":"L’Éternel est ton ombre à ta main droite.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Pendant le jour le soleil ne te frappera point,","poem":1},{"lineBreak":true},{"text":"Ni la lune pendant la nuit.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"L’Éternel te gardera de tout mal,","poem":1},{"lineBreak":true},{"text":"Il gardera ton âme;","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"L’Éternel gardera ton départ et ton arrivée,","poem":1},{"lineBreak":true},{"text":"Dès maintenant et à jamais.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/121.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/122.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/120.json","previousChapterAudioLinks":{},"numberOfVerses":8}