{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":93,"content":[{"type":"verse","number":1,"content":[{"text":"L’Éternel règne, il est revêtu de majesté,","poem":1},{"lineBreak":true},{"text":"L’Éternel est revêtu, il est ceint de force.","poem":1},{"lineBreak":true},{"text":"Aussi le monde est ferme, il ne chancelle pas.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Ton trône est établi dès les temps anciens;","poem":1},{"lineBreak":true},{"text":"Tu existes de toute éternité.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Les fleuves élèvent, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Les fleuves élèvent leur voix,","poem":1},{"lineBreak":true},{"text":"Les fleuves élèvent leurs ondes retentissantes.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Plus que la voix des grandes, des puissantes eaux,","poem":1},{"lineBreak":true},{"text":"Des flots impétueux de la mer,","poem":1},{"lineBreak":true},{"text":"L’Éternel est puissant dans les lieux célestes.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Tes témoignages sont entièrement véritables;","poem":1},{"lineBreak":true},{"text":"La sainteté convient à ta maison,","poem":1},{"lineBreak":true},{"text":"O Éternel! Pour toute la durée des temps.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/93.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/94.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/92.json","previousChapterAudioLinks":{},"numberOfVerses":5}