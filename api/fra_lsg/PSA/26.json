{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":26,"content":[{"type":"verse","number":1,"content":[{"text":"De David.","poem":1},{"lineBreak":true},{"text":"Rends-moi justice, Éternel!","poem":1},{"lineBreak":true},{"text":"Car je marche dans l’intégrité,","poem":1},{"lineBreak":true},{"text":"Je me confie en l’Éternel, je ne chancelle pas.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Sonde-moi, Éternel! Éprouve-moi,","poem":1},{"lineBreak":true},{"text":"Fais passer au creuset mes reins et mon cœur;","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Car ta grâce est devant mes yeux,","poem":1},{"lineBreak":true},{"text":"Et je marche dans ta vérité.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Je ne m’assieds pas avec les hommes faux,","poem":1},{"lineBreak":true},{"text":"Je ne vais pas avec les gens dissimulés;","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Je hais l’assemblée de ceux qui font le mal,","poem":1},{"lineBreak":true},{"text":"Je ne m’assieds pas avec les méchants.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Je lave mes mains dans l’innocence,","poem":1},{"lineBreak":true},{"text":"Et je vais autour de ton autel, ô Éternel!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Pour éclater en actions de grâces,","poem":1},{"lineBreak":true},{"text":"Et raconter toutes tes merveilles.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Éternel! J’aime le séjour de ta maison,","poem":1},{"lineBreak":true},{"text":"Le lieu où ta gloire habite.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"N’enlève pas mon âme avec les pécheurs,","poem":1},{"lineBreak":true},{"text":"Ma vie avec les hommes de sang,","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Dont les mains sont criminelles","poem":1},{"lineBreak":true},{"text":"Et la droite pleine de présents!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Moi, je marche dans l’intégrité;","poem":1},{"lineBreak":true},{"text":"Délivre-moi et aie pitié de moi!","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Mon pied est ferme dans la droiture:","poem":1},{"lineBreak":true},{"text":"Je bénirai l’Éternel dans les assemblées.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/26.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/27.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/25.json","previousChapterAudioLinks":{},"numberOfVerses":12}