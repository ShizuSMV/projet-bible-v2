{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":3,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume de David. A l’occasion de sa fuite devant Absalom, son fils.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"O Éternel, que mes ennemis sont nombreux!","poem":1},{"lineBreak":true},{"text":"Quelle multitude se lève contre moi!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Combien qui disent à mon sujet:","poem":1},{"lineBreak":true},{"text":"Plus de salut pour lui auprès de Dieu! — Pause.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Mais toi, ô Éternel! Tu es mon bouclier,","poem":1},{"lineBreak":true},{"text":"Tu es ma gloire, et tu relèves ma tête.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"De ma voix je crie à l’Éternel,","poem":1},{"lineBreak":true},{"text":"Et il me répond de sa montagne sainte. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Je me couche, et je m’endors;","poem":1},{"lineBreak":true},{"text":"Je me réveille, car l’Éternel est mon soutien.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je ne crains pas les myriades de peuples","poem":1},{"lineBreak":true},{"text":"Qui m’assiègent de toutes parts.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Lève-toi, Éternel! Sauve-moi, mon Dieu!","poem":1},{"lineBreak":true},{"text":"Car tu frappes à la joue tous mes ennemis,","poem":1},{"lineBreak":true},{"text":"Tu brises les dents des méchants.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Le salut est auprès de l’Éternel:","poem":1},{"lineBreak":true},{"text":"Que ta bénédiction soit sur ton peuple! — Pause.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/2.json","previousChapterAudioLinks":{},"numberOfVerses":9}