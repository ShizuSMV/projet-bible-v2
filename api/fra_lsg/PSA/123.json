es moqueries des orgueilleux, du mépris des hautains.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/123.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/124.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/122.json","previousChapterAudioLinks":{},"numberOfVerses":4}