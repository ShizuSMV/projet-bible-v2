esses devant moi une table,","poem":1},{"lineBreak":true},{"text":"En face de mes adversaires;","poem":1},{"lineBreak":true},{"text":"Tu oins d’huile ma tête,","poem":1},{"lineBreak":true},{"text":"Et ma coupe déborde.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Oui, le bonheur et la grâce m’accompagneront","poem":1},{"lineBreak":true},{"text":"Tous les jours de ma vie,","poem":1},{"lineBreak":true},{"text":"Et j’habiterai dans la maison de l’Éternel","poem":1},{"lineBreak":true},{"text":"Jusqu’à la fin de mes jours.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/23.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/24.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/22.json","previousChapterAudioLinks":{},"numberOfVerses":6}