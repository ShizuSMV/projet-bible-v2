{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":62,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. D’après Jeduthun. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Oui, c’est en Dieu que mon âme se confie;","poem":1},{"lineBreak":true},{"text":"De lui vient mon salut.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Oui, c’est lui qui est mon rocher et mon salut;","poem":1},{"lineBreak":true},{"text":"Ma haute retraite: je ne chancellerai guère.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Jusqu’à quand vous jetterez-vous sur un homme,","poem":1},{"lineBreak":true},{"text":"Chercherez-vous tous à l’abattre,","poem":1},{"lineBreak":true},{"text":"Comme une muraille qui penche,","poem":1},{"lineBreak":true},{"text":"Comme une clôture qu’on renverse?","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Ils conspirent pour le précipiter de son poste élevé;","poem":1},{"lineBreak":true},{"text":"Ils prennent plaisir au mensonge;","poem":1},{"lineBreak":true},{"text":"Ils bénissent de leur bouche,","poem":1},{"lineBreak":true},{"text":"Et ils maudissent dans leur cœur. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Oui, mon âme, confie-toi en Dieu!","poem":1},{"lineBreak":true},{"text":"Car de lui vient mon espérance.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Oui, c’est lui qui est mon rocher et mon salut;","poem":1},{"lineBreak":true},{"text":"Ma haute retraite: je ne chancellerai pas.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Sur Dieu reposent mon salut et ma gloire;","poem":1},{"lineBreak":true},{"text":"Le rocher de ma force, mon refuge, est en Dieu.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"En tout temps, peuples, confiez-vous en lui,","poem":1},{"lineBreak":true},{"text":"Répandez vos cœurs en sa présence!","poem":1},{"lineBreak":true},{"text":"Dieu est notre refuge, — Pause.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Oui, vanité, les fils de l’homme!","poem":1},{"lineBreak":true},{"text":"Mensonge, les fils de l’homme!","poem":1},{"lineBreak":true},{"text":"Dans une balance ils monteraient","poem":1},{"lineBreak":true},{"text":"Tous ensemble, plus légers qu’un souffle.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Ne vous confiez pas dans la violence,","poem":1},{"lineBreak":true},{"text":"Et ne mettez pas un vain espoir dans la rapine;","poem":1},{"lineBreak":true},{"text":"Quand les richesses s’accroissent,","poem":1},{"lineBreak":true},{"text":"N’y attachez pas votre cœur.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Dieu a parlé une fois;","poem":1},{"lineBreak":true},{"text":"Deux fois j’ai entendu ceci:","poem":1},{"lineBreak":true},{"text":"C’est que la force est à Dieu.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"A toi aussi, Seigneur! La bonté;","poem":1},{"lineBreak":true},{"text":"Car tu rends à chacun selon ses œuvres.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/62.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/63.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/61.json","previousChapterAudioLinks":{},"numberOfVerses":13}