,{"lineBreak":true},{"text":"Et c’est le Très-Haut qui l’affermit.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"L’Éternel compte en inscrivant les peuples:","poem":1},{"lineBreak":true},{"text":"C’est là qu’ils sont nés. — Pause.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Et ceux qui chantent et ceux qui dansent s’écrient:","poem":1},{"lineBreak":true},{"text":"Toutes mes sources sont en toi.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/87.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/88.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/86.json","previousChapterAudioLinks":{},"numberOfVerses":7}