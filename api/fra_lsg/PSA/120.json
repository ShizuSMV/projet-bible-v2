{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":120,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés.","poem":1},{"lineBreak":true},{"text":"Dans ma détresse, c’est à l’Éternel","poem":1},{"lineBreak":true},{"text":"Que je crie, et il m’exauce.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Éternel, délivre mon âme de la lèvre mensongère,","poem":1},{"lineBreak":true},{"text":"De la langue trompeuse!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Que te donne, que te rapporte","poem":1},{"lineBreak":true},{"text":"Une langue trompeuse?","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Les traits aigus du guerrier,","poem":1},{"lineBreak":true},{"text":"Avec les charbons ardents du genêt.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Malheureux que je suis de séjourner à Méschec,","poem":1},{"lineBreak":true},{"text":"D’habiter parmi les tentes de Kédar!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Assez longtemps mon âme a demeuré","poem":1},{"lineBreak":true},{"text":"Auprès de ceux qui haïssent la paix.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je suis pour la paix; mais dès que je parle,","poem":1},{"lineBreak":true},{"text":"Ils sont pour la guerre.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/120.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/121.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/119.json","previousChapterAudioLinks":{},"numberOfVerses":7}