{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":124,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés. De David.","poem":1},{"lineBreak":true},{"text":"Sans l’Éternel qui nous protégea,","poem":1},{"lineBreak":true},{"text":"Qu’Israël le dise!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Sans l’Éternel qui nous protégea,","poem":1},{"lineBreak":true},{"text":"Quand les hommes s’élevèrent contre nous,","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Ils nous auraient engloutis tout vivants,","poem":1},{"lineBreak":true},{"text":"Quand leur colère s’enflamma contre nous;","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Alors les eaux nous auraient submergés,","poem":1},{"lineBreak":true},{"text":"Les torrents auraient passé sur notre âme;","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Alors auraient passé sur notre âme","poem":1},{"lineBreak":true},{"text":"Les flots impétueux.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Béni soit l’Éternel,","poem":1},{"lineBreak":true},{"text":"Qui ne nous a pas livrés en proie à leurs dents!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Notre âme s’est échappée comme l’oiseau du filet des oiseleurs;","poem":1},{"lineBreak":true},{"text":"Le filet s’est rompu, et nous nous sommes échappés.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Notre secours est dans le nom de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Qui a fait les cieux et la terre.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/124.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/125.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/123.json","previousChapterAudioLinks":{},"numberOfVerses":8}