{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":54,"content":[{"type":"verse","number":1,"content":["Au chef des chantres. Avec instruments à cordes. Cantique de David."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Lorsque les Ziphiens vinrent dire à Saül: David n’est-il pas caché parmi nous?","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"O Dieu! Sauve-moi par ton nom,","poem":1},{"lineBreak":true},{"text":"Et rends-moi justice par ta puissance!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"O Dieu! Écoute ma prière,","poem":1},{"lineBreak":true},{"text":"Prête l’oreille aux paroles de ma bouche!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Car des étrangers se sont levés contre moi,","poem":1},{"lineBreak":true},{"text":"Des hommes violents en veulent à ma vie;","poem":1},{"lineBreak":true},{"text":"Ils ne portent pas leurs pensées sur Dieu. — Pause.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Voici, Dieu est mon secours,","poem":1},{"lineBreak":true},{"text":"Le Seigneur est le soutien de mon âme.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Le mal retombera sur mes adversaires;","poem":1},{"lineBreak":true},{"text":"Anéantis-les, dans ta fidélité!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Je t’offrirai de bon cœur des sacrifices;","poem":1},{"lineBreak":true},{"text":"Je louerai ton nom, ô Éternel! car il est favorable,","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Car il me délivre de toute détresse,","poem":1},{"lineBreak":true},{"text":"Et mes yeux se réjouissent à la vue de mes ennemis.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/54.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/55.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/53.json","previousChapterAudioLinks":{},"numberOfVerses":9}