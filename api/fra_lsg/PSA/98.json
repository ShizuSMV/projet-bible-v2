{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":98,"content":[{"type":"verse","number":1,"content":[{"text":"Psaume.","poem":1},{"lineBreak":true},{"text":"Chantez à l’Éternel un cantique nouveau!","poem":1},{"lineBreak":true},{"text":"Car il a fait des prodiges.","poem":1},{"lineBreak":true},{"text":"Sa droite et son bras saint lui sont venus en aide.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"L’Éternel a manifesté son salut,","poem":1},{"lineBreak":true},{"text":"Il a révélé sa justice aux yeux des nations.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Il s’est souvenu de sa bonté et de sa fidélité envers la maison d’Israël,","poem":1},{"lineBreak":true},{"text":"Toutes les extrémités de la terre ont vu le salut de notre Dieu.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Poussez vers l’Éternel des cris de joie,","poem":1},{"lineBreak":true},{"text":"Vous tous, habitants de la terre!","poem":1},{"lineBreak":true},{"text":"Faites éclater votre allégresse, et chantez!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Chantez à l’Éternel avec la harpe;","poem":1},{"lineBreak":true},{"text":"Avec la harpe chantez des cantiques!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Avec les trompettes et au son du cor,","poem":1},{"lineBreak":true},{"text":"Poussez des cris de joie devant le roi, l’Éternel!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Que la mer retentisse avec tout ce qu’elle contient,","poem":1},{"lineBreak":true},{"text":"Que le monde et ceux qui l’habitent éclatent d’allégresse,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Que les fleuves battent des mains,","poem":1},{"lineBreak":true},{"text":"Que toutes les montagnes poussent des cris de joie,","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Devant l’Éternel! Car il vient pour juger la terre;","poem":1},{"lineBreak":true},{"text":"Il jugera le monde avec justice,","poem":1},{"lineBreak":true},{"text":"Et les peuples avec équité.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/98.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/99.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/97.json","previousChapterAudioLinks":{},"numberOfVerses":9}