{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":76,"content":[{"type":"verse","number":1,"content":["Au chef des chantres. Avec instruments à cordes. Psaume d’Asaph. Cantique."]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Dieu est connu en Juda,","poem":1},{"lineBreak":true},{"text":"Son nom est grand en Israël.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Sa tente est à Salem,","poem":1},{"lineBreak":true},{"text":"Et sa demeure à Sion.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"C’est là qu’il a brisé les flèches,","poem":1},{"lineBreak":true},{"text":"Le bouclier, l’épée et les armes de guerre. — Pause.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Tu es plus majestueux, plus puissant","poem":1},{"lineBreak":true},{"text":"Que les montagnes des ravisseurs.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Ils ont été dépouillés, ces héros pleins de courage,","poem":1},{"lineBreak":true},{"text":"Ils se sont endormis de leur dernier sommeil;","poem":1},{"lineBreak":true},{"text":"Ils n’ont pas su se défendre, tous ces vaillants hommes.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"A ta menace, Dieu de Jacob!","poem":1},{"lineBreak":true},{"text":"Ils se sont endormis, cavaliers et chevaux.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Tu es redoutable, ô toi!","poem":1},{"lineBreak":true},{"text":"Qui peut te résister, quand ta colère éclate?","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Du haut des cieux tu as proclamé la sentence;","poem":1},{"lineBreak":true},{"text":"La terre effrayée s’est tenue tranquille,","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Lorsque Dieu s’est levé pour faire justice,","poem":1},{"lineBreak":true},{"text":"Pour sauver tous les malheureux de la terre. — Pause.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"L’homme te célèbre même dans sa fureur,","poem":1},{"lineBreak":true},{"text":"Quand tu te revêts de tout ton courroux.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Faites des vœux à l’Éternel, votre Dieu, et accomplissez-les!","poem":1},{"lineBreak":true},{"text":"Que tous ceux qui l’environnent apportent des dons au Dieu terrible!","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Il abat l’orgueil des princes,","poem":1},{"lineBreak":true},{"text":"Il est redoutable aux rois de la terre.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/76.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/77.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/75.json","previousChapterAudioLinks":{},"numberOfVerses":13}