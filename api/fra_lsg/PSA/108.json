{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":108,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Mon cœur est affermi, ô Dieu!","poem":1},{"lineBreak":true},{"text":"Je chanterai, je ferai retentir mes instruments: c’est ma gloire!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Réveillez-vous, mon luth et ma harpe!","poem":1},{"lineBreak":true},{"text":"Je réveillerai l’aurore.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Je te louerai parmi les peuples, Éternel!","poem":1},{"lineBreak":true},{"text":"Je te chanterai parmi les nations.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Car ta bonté s’élève au-dessus des cieux,","poem":1},{"lineBreak":true},{"text":"Et ta fidélité jusqu’aux nues.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Élève-toi sur les cieux, ô Dieu!","poem":1},{"lineBreak":true},{"text":"Et que ta gloire soit sur toute la terre!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Afin que tes bien-aimés soient délivrés,","poem":1},{"lineBreak":true},{"text":"Sauve par ta droite, et exauce-nous!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Dieu a dit dans sa sainteté: Je triompherai,","poem":1},{"lineBreak":true},{"text":"Je partagerai Sichem, je mesurerai la vallée de Succoth;","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"A moi Galaad, à moi Manassé;","poem":1},{"lineBreak":true},{"text":"Éphraïm est le rempart de ma tête,","poem":1},{"lineBreak":true},{"text":"Et Juda, mon sceptre;","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Moab est le bassin où je me lave;","poem":1},{"lineBreak":true},{"text":"Je jette mon soulier sur Édom;","poem":1},{"lineBreak":true},{"text":"Je pousse des cris de joie sur le pays des Philistins!","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Qui me mènera dans la ville forte?","poem":1},{"lineBreak":true},{"text":"Qui me conduit à Édom?","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"N’est-ce pas toi, ô Dieu, qui nous as repoussés,","poem":1},{"lineBreak":true},{"text":"Et qui ne sortais plus, ô Dieu, avec nos armées?","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Donne-nous du secours contre la détresse!","poem":1},{"lineBreak":true},{"text":"Le secours de l’homme n’est que vanité.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Avec Dieu, nous ferons des exploits;","poem":1},{"lineBreak":true},{"text":"Il écrasera nos ennemis.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/108.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/109.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/107.json","previousChapterAudioLinks":{},"numberOfVerses":14}