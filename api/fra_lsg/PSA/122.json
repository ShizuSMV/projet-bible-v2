{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":122,"content":[{"type":"verse","number":1,"content":[{"text":"Cantique des degrés. De David.","poem":1},{"lineBreak":true},{"text":"Je suis dans la joie quand on me dit:","poem":1},{"lineBreak":true},{"text":"Allons à la maison de l’Éternel!","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Nos pieds s’arrêtent","poem":1},{"lineBreak":true},{"text":"Dans tes portes, Jérusalem!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Jérusalem, tu es bâtie","poem":1},{"lineBreak":true},{"text":"Comme une ville dont les parties sont liées ensemble.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"C’est là que montent les tribus, les tribus de l’Éternel,","poem":1},{"lineBreak":true},{"text":"Selon la loi d’Israël,","poem":1},{"lineBreak":true},{"text":"Pour louer le nom de l’Éternel.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Car là sont les trônes pour la justice,","poem":1},{"lineBreak":true},{"text":"Les trônes de la maison de David.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Demandez la paix de Jérusalem.","poem":1},{"lineBreak":true},{"text":"Que ceux qui t’aiment jouissent du repos!","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Que la paix soit dans tes murs,","poem":1},{"lineBreak":true},{"text":"Et la tranquillité dans tes palais!","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"A cause de mes frères et de mes amis,","poem":1},{"lineBreak":true},{"text":"Je désire la paix dans ton sein;","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"A cause de la maison de l’Éternel, notre Dieu,","poem":1},{"lineBreak":true},{"text":"Je fais des vœux pour ton bonheur.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/122.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/123.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/121.json","previousChapterAudioLinks":{},"numberOfVerses":9}