{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":85,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Des fils de Koré. Psaume.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Tu as été favorable à ton pays, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Tu as ramené les captifs de Jacob;","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Tu as pardonné l’iniquité de ton peuple,","poem":1},{"lineBreak":true},{"text":"Tu as couvert tous ses péchés; — Pause.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Tu as retiré toute ta fureur,","poem":1},{"lineBreak":true},{"text":"Tu es revenu de l’ardeur de ta colère.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Rétablis-nous, Dieu de notre salut!","poem":1},{"lineBreak":true},{"text":"Cesse ton indignation contre nous!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"T’irriteras-tu contre nous à jamais?","poem":1},{"lineBreak":true},{"text":"Prolongeras-tu ta colère éternellement?","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Ne nous rendras-tu pas à la vie,","poem":1},{"lineBreak":true},{"text":"Afin que ton peuple se réjouisse en toi?","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Éternel! Fais-nous voir ta bonté,","poem":1},{"lineBreak":true},{"text":"Et accorde-nous ton salut!","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"J’écouterai ce que dit Dieu, l’Éternel;","poem":1},{"lineBreak":true},{"text":"Car il parle de paix à son peuple et à ses fidèles,","poem":1},{"lineBreak":true},{"text":"Pourvu qu’ils ne retombent pas dans la folie.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Oui, son salut est près de ceux qui le craignent,","poem":1},{"lineBreak":true},{"text":"Afin que la gloire habite dans notre pays.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"La bonté et la fidélité se rencontrent,","poem":1},{"lineBreak":true},{"text":"La justice et la paix s’embrassent;","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"La fidélité germe de la terre,","poem":1},{"lineBreak":true},{"text":"Et la justice regarde du haut des cieux.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"L’Éternel aussi accordera le bonheur,","poem":1},{"lineBreak":true},{"text":"Et notre terre donnera ses fruits.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"La justice marchera devant lui,","poem":1},{"lineBreak":true},{"text":"Et imprimera ses pas sur le chemin.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/85.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/86.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/84.json","previousChapterAudioLinks":{},"numberOfVerses":14}