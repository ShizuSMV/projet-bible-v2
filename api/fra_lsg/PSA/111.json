{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":111,"content":[{"type":"verse","number":1,"content":[{"text":"Louez l’Éternel!","poem":1},{"lineBreak":true},{"text":"Je louerai l’Éternel de tout mon cœur,","poem":1},{"lineBreak":true},{"text":"Dans la réunion des hommes droits et dans l’assemblée.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Les œuvres de l’Éternel sont grandes,","poem":1},{"lineBreak":true},{"text":"Recherchées par tous ceux qui les aiment.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Son œuvre n’est que splendeur et magnificence,","poem":1},{"lineBreak":true},{"text":"Et sa justice subsiste à jamais.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Il a laissé la mémoire de ses prodiges,","poem":1},{"lineBreak":true},{"text":"L’Éternel miséricordieux et compatissant.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Il a donné de la nourriture à ceux qui le craignent;","poem":1},{"lineBreak":true},{"text":"Il se souvient toujours de son alliance.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Il a manifesté à son peuple la puissance de ses œuvres,","poem":1},{"lineBreak":true},{"text":"En lui livrant l’héritage des nations.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Les œuvres de ses mains sont fidélité et justice;","poem":1},{"lineBreak":true},{"text":"Toutes ses ordonnances sont véritables,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Affermies pour l’éternité,","poem":1},{"lineBreak":true},{"text":"Faites avec fidélité et droiture.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Il a envoyé la délivrance à son peuple,","poem":1},{"lineBreak":true},{"text":"Il a établi pour toujours son alliance;","poem":1},{"lineBreak":true},{"text":"Son nom est saint et redoutable.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"La crainte de l’Éternel est le commencement de la sagesse;","poem":1},{"lineBreak":true},{"text":"Tous ceux qui l’observent ont une raison saine.","poem":1},{"lineBreak":true},{"text":"Sa gloire subsiste à jamais.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/111.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/112.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/110.json","previousChapterAudioLinks":{},"numberOfVerses":10}