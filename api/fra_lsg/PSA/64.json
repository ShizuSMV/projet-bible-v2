{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":64,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"O Dieu, écoute ma voix, quand je gémis!","poem":1},{"lineBreak":true},{"text":"Protège ma vie contre l’ennemi que je crains!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Garantis-moi des complots des méchants,","poem":1},{"lineBreak":true},{"text":"De la troupe bruyante des hommes iniques!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Ils aiguisent leur langue comme un glaive,","poem":1},{"lineBreak":true},{"text":"Ils lancent comme des traits leurs paroles amères,","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Pour tirer en cachette sur l’innocent;","poem":1},{"lineBreak":true},{"text":"Ils tirent sur lui à l’improviste, et n’ont aucune crainte.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Ils se fortifient dans leur méchanceté:","poem":1},{"lineBreak":true},{"text":"Ils se concertent pour tendre des pièges,","poem":1},{"lineBreak":true},{"text":"Ils disent: Qui les verra?","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Ils méditent des crimes: Nous voici prêts, le plan est conçu!","poem":1},{"lineBreak":true},{"text":"La pensée intime, le cœur de chacun est un abîme.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Dieu lance contre eux ses traits:","poem":1},{"lineBreak":true},{"text":"Soudain les voilà frappés.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Leur langue a causé leur chute;","poem":1},{"lineBreak":true},{"text":"Tous ceux qui les voient secouent la tête.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Tous les hommes sont saisis de crainte,","poem":1},{"lineBreak":true},{"text":"Ils publient ce que Dieu fait,","poem":1},{"lineBreak":true},{"text":"Et prennent garde à son œuvre.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Le juste se réjouit en l’Éternel et cherche en lui son refuge,","poem":1},{"lineBreak":true},{"text":"Tous ceux qui ont le cœur droit se glorifient.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/64.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/65.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/63.json","previousChapterAudioLinks":{},"numberOfVerses":11}