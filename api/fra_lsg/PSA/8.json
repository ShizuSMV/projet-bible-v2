{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":8,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Sur la guitthith. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Éternel, notre Seigneur!","poem":1},{"lineBreak":true},{"text":"Que ton nom est magnifique sur toute la terre!","poem":1},{"lineBreak":true},{"text":"Ta majesté s’élève au-dessus des cieux.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Par la bouche des enfants et de ceux qui sont à la mamelle","poem":1},{"lineBreak":true},{"text":"Tu as fondé ta gloire, pour confondre tes adversaires,","poem":1},{"lineBreak":true},{"text":"Pour imposer silence à l’ennemi et au vindicatif.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Quand je contemple les cieux, ouvrage de tes mains,","poem":1},{"lineBreak":true},{"text":"La lune et les étoiles que tu as créées:","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Qu’est-ce que l’homme, pour que tu te souviennes de lui?","poem":1},{"lineBreak":true},{"text":"Et le fils de l’homme, pour que tu prennes garde à lui?","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Tu l’as fait de peu inférieur à Dieu,","poem":1},{"lineBreak":true},{"text":"Et tu l’as couronné de gloire et de magnificence.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Tu lui as donné la domination sur les œuvres de tes mains,","poem":1},{"lineBreak":true},{"text":"Tu as tout mis sous ses pieds,","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Les brebis comme les bœufs,","poem":1},{"lineBreak":true},{"text":"Et les animaux des champs,","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Les oiseaux du ciel et les poissons de la mer,","poem":1},{"lineBreak":true},{"text":"Tout ce qui parcourt les sentiers des mers.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Éternel, notre Seigneur!","poem":1},{"lineBreak":true},{"text":"Que ton nom est magnifique sur toute la terre!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/8.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/9.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/7.json","previousChapterAudioLinks":{},"numberOfVerses":10}