{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":6,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Avec instruments à cordes. Sur la harpe à huit cordes. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Éternel! ne me punis pas dans ta colère,","poem":1},{"lineBreak":true},{"text":"Et ne me châtie pas dans ta fureur.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Aie pitié de moi, Éternel! Car je suis sans force;","poem":1},{"lineBreak":true},{"text":"Guéris-moi, Éternel! Car mes os sont tremblants.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Mon âme est toute troublée;","poem":1},{"lineBreak":true},{"text":"Et toi, Éternel! Jusques à quand?…","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Reviens, Éternel! Délivre mon âme;","poem":1},{"lineBreak":true},{"text":"Sauve-moi, à cause de ta miséricorde.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Car celui qui meurt n’a plus ton souvenir;","poem":1},{"lineBreak":true},{"text":"Qui te louera dans le séjour des morts?","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Je m’épuise à force de gémir;","poem":1},{"lineBreak":true},{"text":"Chaque nuit ma couche est baignée de mes larmes,","poem":1},{"lineBreak":true},{"text":"Mon lit est arrosé de mes pleurs.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"J’ai le visage usé par le chagrin;","poem":1},{"lineBreak":true},{"text":"Tous ceux qui me persécutent le font vieillir.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Éloignez-vous de moi, vous tous qui faites le mal!","poem":1},{"lineBreak":true},{"text":"Car l’Éternel entend la voix de mes larmes;","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"L’Éternel exauce mes supplications,","poem":1},{"lineBreak":true},{"text":"L’Éternel accueille ma prière.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Tous mes ennemis sont confondus, saisis d’épouvante;","poem":1},{"lineBreak":true},{"text":"Ils reculent, soudain couverts de honte.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/6.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/7.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/5.json","previousChapterAudioLinks":{},"numberOfVerses":11}