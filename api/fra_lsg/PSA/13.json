{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":13,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. Psaume de David.","poem":1}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"Jusques à quand, Éternel! M’oublieras-tu sans cesse?","poem":1},{"lineBreak":true},{"text":"Jusques à quand me cacheras-tu ta face?","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Jusques à quand aurai-je des soucis dans mon âme,","poem":1},{"lineBreak":true},{"text":"Et chaque jour des chagrins dans mon cœur?","poem":1},{"lineBreak":true},{"text":"Jusques à quand mon ennemi s’élèvera-t-il contre moi?","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Regarde, réponds-moi, Éternel, mon Dieu!","poem":1},{"lineBreak":true},{"text":"Donne à mes yeux la clarté,","poem":1},{"lineBreak":true},{"text":"Afin que je ne m’endorme pas du sommeil de la mort,","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Afin que mon ennemi ne dise pas: Je l’ai vaincu!","poem":1},{"lineBreak":true},{"text":"Et que mes adversaires ne se réjouissent pas, si je chancelle.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Moi, j’ai confiance en ta bonté,","poem":1},{"lineBreak":true},{"text":"J’ai de l’allégresse dans le cœur, à cause de ton salut;","poem":1},{"lineBreak":true},{"text":"Je chante à l’Éternel, car il m’a fait du bien.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/13.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/14.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/12.json","previousChapterAudioLinks":{},"numberOfVerses":6}