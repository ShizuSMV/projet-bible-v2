{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"PSA","translationId":"fra_lsg","name":"PSAUMES","commonName":"PSAUMES","title":"LES PSAUMES","order":19,"numberOfChapters":150,"sha256":"d621b59ab95a33b0b83bec50003d2d808c27459c855757b30c7b9b08ca625e89","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/fra_lsg/PSA/150.json","totalNumberOfVerses":2527},"chapter":{"number":14,"content":[{"type":"verse","number":1,"content":[{"text":"Au chef des chantres. De David.","poem":1},{"lineBreak":true},{"text":"L’insensé dit en son cœur: Il n’y a point de Dieu!","poem":1},{"lineBreak":true},{"text":"Ils se sont corrompus, ils ont commis des actions abominables;","poem":1},{"lineBreak":true},{"text":"Il n’en est aucun qui fasse le bien.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"L’Éternel, du haut des cieux, regarde les fils de l’homme,","poem":1},{"lineBreak":true},{"text":"Pour voir s’il y a quelqu’un qui soit intelligent,","poem":1},{"lineBreak":true},{"text":"Qui cherche Dieu.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Tous sont égarés, tous sont pervertis;","poem":1},{"lineBreak":true},{"text":"Il n’en est aucun qui fasse le bien,","poem":1},{"lineBreak":true},{"text":"Pas même un seul.","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Tous ceux qui commettent l’iniquité ont-ils perdu le sens?","poem":1},{"lineBreak":true},{"text":"Ils dévorent mon peuple, ils le prennent pour nourriture;","poem":1},{"lineBreak":true},{"text":"Ils n’invoquent point l’Éternel.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"C’est alors qu’ils trembleront d’épouvante,","poem":1},{"lineBreak":true},{"text":"Quand Dieu paraîtra au milieu de la race juste.","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Jetez l’opprobre sur l’espérance du malheureux…","poem":1},{"lineBreak":true},{"text":"L’Éternel est son refuge.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Oh! Qui fera partir de Sion la délivrance d’Israël?","poem":1},{"lineBreak":true},{"text":"Quand l’Éternel ramènera les captifs de son peuple,","poem":1},{"lineBreak":true},{"text":"Jacob sera dans l’allégresse, Israël se réjouira.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/PSA/14.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/PSA/15.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/PSA/13.json","previousChapterAudioLinks":{},"numberOfVerses":7}