{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"JOB","translationId":"fra_lsg","name":"JOB","commonName":"JOB","title":"JOB","order":18,"numberOfChapters":42,"sha256":"58bda4af63a3b67c2daf6de865ed0b0dfa785647b0b355279c796cfe5eb8186c","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/JOB/1.json","lastChapterNumber":42,"lastChapterApiLink":"/api/fra_lsg/JOB/42.json","totalNumberOfVerses":1069},"chapter":{"number":26,"content":[{"type":"heading","content":["Réponse de Job à Bildad"]},{"type":"verse","number":1,"content":["Job prit la parole et dit:"]},{"type":"verse","number":2,"content":[{"text":"Comme tu sais bien venir en aide à la faiblesse!","poem":1},{"lineBreak":true},{"text":"Comme tu prêtes secours au bras sans force!","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Quels bons conseils tu donnes à celui qui manque d’intelligence!","poem":1},{"lineBreak":true},{"text":"Quelle abondance de sagesse tu fais paraître!","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"A qui s’adressent tes paroles?","poem":1},{"lineBreak":true},{"text":"Et qui est-ce qui t’inspire?","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Devant Dieu les ombres tremblent","poem":1},{"lineBreak":true},{"text":"Au-dessous des eaux et de leurs habitants;","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Devant lui le séjour des morts est nu,","poem":1},{"lineBreak":true},{"text":"L’abîme n’a point de voile.","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Il étend le septentrion sur le vide,","poem":1},{"lineBreak":true},{"text":"Il suspend la terre sur le néant.","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Il renferme les eaux dans ses nuages,","poem":1},{"lineBreak":true},{"text":"Et les nuages n’éclatent pas sous leur poids.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"Il couvre la face de son trône,","poem":1},{"lineBreak":true},{"text":"Il répand sur lui sa nuée.","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Il a tracé un cercle à la surface des eaux,","poem":1},{"lineBreak":true},{"text":"Comme limite entre la lumière et les ténèbres.","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Les colonnes du ciel s’ébranlent,","poem":1},{"lineBreak":true},{"text":"Et s’étonnent à sa menace.","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"Par sa force il soulève la mer,","poem":1},{"lineBreak":true},{"text":"Par son intelligence il en brise l’orgueil.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"Son souffle donne au ciel la sérénité,","poem":1},{"lineBreak":true},{"text":"Sa main transperce le serpent fuyard.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Ce sont là les bords de ses voies,","poem":1},{"lineBreak":true},{"text":"C’est le bruit léger qui nous en parvient;","poem":1},{"lineBreak":true},{"text":"Mais qui entendra le tonnerre de sa puissance?","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/JOB/26.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/JOB/27.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/JOB/25.json","previousChapterAudioLinks":{},"numberOfVerses":14}