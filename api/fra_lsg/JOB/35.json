{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"JOB","translationId":"fra_lsg","name":"JOB","commonName":"JOB","title":"JOB","order":18,"numberOfChapters":42,"sha256":"58bda4af63a3b67c2daf6de865ed0b0dfa785647b0b355279c796cfe5eb8186c","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/JOB/1.json","lastChapterNumber":42,"lastChapterApiLink":"/api/fra_lsg/JOB/42.json","totalNumberOfVerses":1069},"chapter":{"number":35,"content":[{"type":"verse","number":1,"content":["Élihu reprit et dit:"]},{"type":"verse","number":2,"content":[{"text":"Imagines-tu avoir raison,","poem":1},{"lineBreak":true},{"text":"Penses-tu te justifier devant Dieu,","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Quand tu dis: Que me sert-il,","poem":1},{"lineBreak":true},{"text":"Que me revient-il de ne pas pécher?","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"C’est à toi que je vais répondre,","poem":1},{"lineBreak":true},{"text":"Et à tes amis en même temps.","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Considère les cieux, et regarde!","poem":1},{"lineBreak":true},{"text":"Vois les nuées, comme elles sont au-dessus de toi!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Si tu pèches, quel tort lui causes-tu?","poem":1},{"lineBreak":true},{"text":"Et quand tes péchés se multiplient, que lui fais-tu?","poem":1}]},{"type":"verse","number":7,"content":[{"lineBreak":true},{"text":"Si tu es juste, que lui donnes-tu?","poem":1},{"lineBreak":true},{"text":"Que reçoit-il de ta main?","poem":1}]},{"type":"verse","number":8,"content":[{"lineBreak":true},{"text":"Ta méchanceté ne peut nuire qu’à ton semblable,","poem":1},{"lineBreak":true},{"text":"Ta justice n’est utile qu’au fils de l’homme.","poem":1}]},{"type":"verse","number":9,"content":[{"lineBreak":true},{"text":"On crie contre la multitude des oppresseurs,","poem":1},{"lineBreak":true},{"text":"On se plaint de la violence d’un grand nombre;","poem":1}]},{"type":"verse","number":10,"content":[{"lineBreak":true},{"text":"Mais nul ne dit: Où est Dieu, mon créateur,","poem":1},{"lineBreak":true},{"text":"Qui inspire des chants d’allégresse pendant la nuit,","poem":1}]},{"type":"verse","number":11,"content":[{"lineBreak":true},{"text":"Qui nous instruit plus que les bêtes de la terre,","poem":1},{"lineBreak":true},{"text":"Et nous donne l’intelligence plus qu’aux oiseaux du ciel?","poem":1}]},{"type":"verse","number":12,"content":[{"lineBreak":true},{"text":"On a beau crier alors, Dieu ne répond pas,","poem":1},{"lineBreak":true},{"text":"A cause de l’orgueil des méchants.","poem":1}]},{"type":"verse","number":13,"content":[{"lineBreak":true},{"text":"C’est en vain que l’on crie, Dieu n’écoute pas,","poem":1},{"lineBreak":true},{"text":"Le Tout-Puissant n’y a point égard.","poem":1}]},{"type":"verse","number":14,"content":[{"lineBreak":true},{"text":"Bien que tu dises que tu ne le vois pas,","poem":1},{"lineBreak":true},{"text":"Ta cause est devant lui: attends-le!","poem":1}]},{"type":"verse","number":15,"content":[{"lineBreak":true},{"text":"Mais, parce que sa colère ne sévit point encore,","poem":1},{"lineBreak":true},{"text":"Ce n’est pas à dire qu’il ait peu souci du crime.","poem":1}]},{"type":"verse","number":16,"content":[{"lineBreak":true},{"text":"Ainsi Job ouvre vainement la bouche,","poem":1},{"lineBreak":true},{"text":"Il multiplie les paroles sans intelligence.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/JOB/35.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/JOB/36.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/JOB/34.json","previousChapterAudioLinks":{},"numberOfVerses":16}