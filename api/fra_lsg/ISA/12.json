{"translation":{"id":"fra_lsg","name":"Louis Segond 1910","website":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseUrl":"https://ebible.org/Scriptures/details.php?id=fraLSG","licenseNotes":null,"shortName":"LSG","englishName":"French Louis Segond 1910 Bible","language":"fra","textDirection":"ltr","sha256":"511c6bdbe3244cdc9f86b3d119bf7b1a1aa101fa70dc70395ff662b528ce2c39","availableFormats":["json"],"listOfBooksApiLink":"/api/fra_lsg/books.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31170,"languageName":"français","languageEnglishName":"French"},"book":{"id":"ISA","translationId":"fra_lsg","name":"ÉSAÏE","commonName":"ÉSAÏE","title":"ÉSAÏE","order":23,"numberOfChapters":66,"sha256":"fefef2a2b6d21b8f8d301e4a725ab6d4d336d5ec2422e50e19c96291cacfb01c","firstChapterNumber":1,"firstChapterApiLink":"/api/fra_lsg/ISA/1.json","lastChapterNumber":66,"lastChapterApiLink":"/api/fra_lsg/ISA/66.json","totalNumberOfVerses":1291},"chapter":{"number":12,"content":[{"type":"heading","content":["Chant de délivrance"]},{"type":"verse","number":1,"content":[{"text":"Tu diras en ce jour-là:","poem":1},{"lineBreak":true},{"text":"Je te loue, ô Éternel!","poem":1},{"lineBreak":true},{"text":"Car tu as été irrité contre moi,","poem":1},{"lineBreak":true},{"text":"Ta colère s’est apaisée, et tu m’as consolé.","poem":1}]},{"type":"verse","number":2,"content":[{"lineBreak":true},{"text":"Voici, Dieu est ma délivrance,","poem":1},{"lineBreak":true},{"text":"Je serai plein de confiance, et je ne craindrai rien;","poem":1},{"lineBreak":true},{"text":"Car l’Éternel, l’Éternel est ma force et le sujet de mes louanges;","poem":1},{"lineBreak":true},{"text":"C’est lui qui m’a sauvé.","poem":1}]},{"type":"verse","number":3,"content":[{"lineBreak":true},{"text":"Vous puiserez de l’eau avec joie","poem":1},{"lineBreak":true},{"text":"Aux sources du salut,","poem":1}]},{"type":"verse","number":4,"content":[{"lineBreak":true},{"text":"Et vous direz en ce jour-là:","poem":1},{"lineBreak":true},{"text":"Louez l’Éternel, invoquez son nom,","poem":1},{"lineBreak":true},{"text":"Publiez ses œuvres parmi les peuples,","poem":1},{"lineBreak":true},{"text":"Rappelez la grandeur de son nom!","poem":1}]},{"type":"verse","number":5,"content":[{"lineBreak":true},{"text":"Célébrez l’Éternel, car il a fait des choses magnifiques:","poem":1},{"lineBreak":true},{"text":"Qu’elles soient connues par toute la terre!","poem":1}]},{"type":"verse","number":6,"content":[{"lineBreak":true},{"text":"Pousse des cris de joie et d’allégresse, habitant de Sion!","poem":1},{"lineBreak":true},{"text":"Car il est grand au milieu de toi, le Saint d’Israël.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/fra_lsg/ISA/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/fra_lsg/ISA/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/fra_lsg/ISA/11.json","previousChapterAudioLinks":{},"numberOfVerses":6}